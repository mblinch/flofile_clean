import 'package:flutter/material.dart';
import 'package:file_picker/file_picker.dart';
import 'dart:async';
import '../services/api_manager.dart';

class StartupDialog extends StatefulWidget {
  final Function(String folderPath, String? homeTeam, String? awayTeam)
      onConfigurationComplete;

  const StartupDialog({
    Key? key,
    required this.onConfigurationComplete,
  }) : super(key: key);

  @override
  State<StartupDialog> createState() => _StartupDialogState();
}

class _StartupDialogState extends State<StartupDialog> {
  String? selectedFolderPath;
  String? selectedHomeTeam;
  String? selectedAwayTeam;
  List<String> availableTeams = [];
  bool isLoadingTeams = true;
  bool isLoadingFolder = false;

  // Questionnaire state
  int currentQuestion = 0;
  String displayedText = '';
  bool isTyping = false;
  int typingIndex = 0;
  Timer? typingTimer;

  final ApiManager _apiManager = ApiManager();

  final List<String> questions = [
    'Where is your images folder?',
    'What teams are playing?',
  ];

  @override
  void initState() {
    super.initState();
    _loadTeams();
  }

  Future<void> _loadTeams() async {
    try {
      final teams = await _apiManager.fetchTeams();
      setState(() {
        availableTeams = teams.map((team) => team.name).toList();
        isLoadingTeams = false;
      });
    } catch (e) {
      print('Error loading teams: $e');
      setState(() {
        isLoadingTeams = false;
      });
    }
  }

  Future<void> _pickFolder() async {
    setState(() {
      isLoadingFolder = true;
    });

    try {
      String? result = await FilePicker.platform.getDirectoryPath(
        dialogTitle: 'Select folder containing your images',
      );

      setState(() {
        selectedFolderPath = result;
        isLoadingFolder = false;
      });
    } catch (e) {
      print('Error picking folder: $e');
      setState(() {
        isLoadingFolder = false;
      });
    }
  }

  bool get _canProceed {
    return selectedFolderPath != null &&
        selectedHomeTeam != null &&
        selectedAwayTeam != null &&
        selectedHomeTeam != selectedAwayTeam;
  }

  @override
  Widget build(BuildContext context) {
    return Dialog(
      shape: RoundedRectangleBorder(
        borderRadius: BorderRadius.circular(16),
      ),
      child: Container(
        width: 500,
        padding: const EdgeInsets.all(24),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            // Header
            const Text(
              'FLO FILE',
              style: TextStyle(
                fontSize: 20,
                fontWeight: FontWeight.bold,
                color: Colors.black,
                letterSpacing: -0.5,
              ),
            ),
            const SizedBox(height: 8),
            const Text(
              'Please configure your settings to get started',
              style: TextStyle(
                fontSize: 14,
                color: Colors.grey,
              ),
            ),
            const SizedBox(height: 24),

            // Image Folder Selection
            const Text(
              '1. Select Image Folder',
              style: TextStyle(
                fontSize: 16,
                fontWeight: FontWeight.w600,
              ),
            ),
            const SizedBox(height: 8),
            ElevatedButton.icon(
              onPressed: isLoadingFolder ? null : _pickFolder,
              icon: isLoadingFolder
                  ? const SizedBox(
                      width: 16,
                      height: 16,
                      child: CircularProgressIndicator(strokeWidth: 2),
                    )
                  : const Icon(Icons.folder_open),
              label:
                  Text(isLoadingFolder ? 'Loading...' : 'Pick Images Folder'),
              style: ElevatedButton.styleFrom(
                backgroundColor: Colors.blue.shade600,
                foregroundColor: Colors.white,
                padding:
                    const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
              ),
            ),
            const SizedBox(height: 8),
            // Display selected folder path
            if (selectedFolderPath != null)
              Container(
                width: double.infinity,
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                  color: Colors.green.shade50,
                  border: Border.all(color: Colors.green.shade200),
                  borderRadius: BorderRadius.circular(8),
                ),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Row(
                      children: [
                        Icon(Icons.check_circle, color: Colors.green, size: 16),
                        SizedBox(width: 8),
                        Text(
                          'Folder Selected:',
                          style: TextStyle(
                            fontWeight: FontWeight.w600,
                            color: Colors.green,
                          ),
                        ),
                      ],
                    ),
                    const SizedBox(height: 4),
                    Text(
                      selectedFolderPath!,
                      style: const TextStyle(
                        fontSize: 12,
                        color: Colors.grey,
                      ),
                    ),
                  ],
                ),
              ),
            const SizedBox(height: 24),

            // Team Selection
            const Text(
              '2. Select Teams',
              style: TextStyle(
                fontSize: 16,
                fontWeight: FontWeight.w600,
              ),
            ),
            const SizedBox(height: 8),

            // Home Team
            const Text('Home Team:',
                style: TextStyle(fontWeight: FontWeight.w500)),
            const SizedBox(height: 4),
            Container(
              width: double.infinity,
              padding: const EdgeInsets.symmetric(horizontal: 12),
              decoration: BoxDecoration(
                border: Border.all(color: Colors.grey.shade300),
                borderRadius: BorderRadius.circular(8),
              ),
              child: DropdownButtonHideUnderline(
                child: DropdownButton<String>(
                  value: selectedHomeTeam,
                  hint: Text(
                      isLoadingTeams ? 'Loading teams...' : 'Select home team'),
                  isExpanded: true,
                  items: availableTeams.map((team) {
                    return DropdownMenuItem<String>(
                      value: team,
                      child: Text(team),
                    );
                  }).toList(),
                  onChanged: isLoadingTeams
                      ? null
                      : (value) {
                          setState(() {
                            selectedHomeTeam = value;
                          });
                        },
                ),
              ),
            ),
            const SizedBox(height: 16),

            // Away Team
            const Text('Away Team:',
                style: TextStyle(fontWeight: FontWeight.w500)),
            const SizedBox(height: 4),
            Container(
              width: double.infinity,
              padding: const EdgeInsets.symmetric(horizontal: 12),
              decoration: BoxDecoration(
                border: Border.all(color: Colors.grey.shade300),
                borderRadius: BorderRadius.circular(8),
              ),
              child: DropdownButtonHideUnderline(
                child: DropdownButton<String>(
                  value: selectedAwayTeam,
                  hint: Text(
                      isLoadingTeams ? 'Loading teams...' : 'Select away team'),
                  isExpanded: true,
                  items: availableTeams.map((team) {
                    return DropdownMenuItem<String>(
                      value: team,
                      child: Text(team),
                    );
                  }).toList(),
                  onChanged: isLoadingTeams
                      ? null
                      : (value) {
                          setState(() {
                            selectedAwayTeam = value;
                          });
                        },
                ),
              ),
            ),
            const SizedBox(height: 24),

            // Error message if same team selected
            if (selectedHomeTeam != null &&
                selectedAwayTeam != null &&
                selectedHomeTeam == selectedAwayTeam)
              Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: Colors.red.shade50,
                  border: Border.all(color: Colors.red.shade200),
                  borderRadius: BorderRadius.circular(4),
                ),
                child: const Row(
                  children: [
                    Icon(Icons.error, color: Colors.red, size: 16),
                    SizedBox(width: 8),
                    Text(
                      'Home and away teams must be different',
                      style: TextStyle(color: Colors.red),
                    ),
                  ],
                ),
              ),
            const SizedBox(height: 24),

            // Proceed Button
            SizedBox(
              width: double.infinity,
              child: ElevatedButton(
                onPressed: _canProceed
                    ? () {
                        widget.onConfigurationComplete(
                          selectedFolderPath!,
                          selectedHomeTeam,
                          selectedAwayTeam,
                        );
                      }
                    : null,
                style: ElevatedButton.styleFrom(
                  backgroundColor: Colors.blue.shade600,
                  foregroundColor: Colors.white,
                  padding: const EdgeInsets.symmetric(vertical: 16),
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(8),
                  ),
                ),
                child: const Text(
                  'Start Caption Writer',
                  style: TextStyle(fontSize: 14, fontWeight: FontWeight.w600),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
