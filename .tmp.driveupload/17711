import 'dart:convert';
import 'package:http/http.dart' as http;

class ApiSportsPlayer {
  final String fullName;
  final String firstName;
  final String? jerseyNumber;
  final String displayName;

  ApiSportsPlayer({
    required this.fullName,
    required this.firstName,
    this.jerseyNumber,
    required this.displayName,
  });

  factory ApiSportsPlayer.fromJson(Map<String, dynamic> json) {
    final fullName = json['name'] as String? ?? 'Unknown Player';
    final firstName = fullName.split(' ').first;
    final jerseyNumber = json['number']?.toString();
    final displayName =
        jerseyNumber != null ? '$fullName #$jerseyNumber' : fullName;

    return ApiSportsPlayer(
      fullName: fullName,
      firstName: firstName,
      jerseyNumber: jerseyNumber,
      displayName: displayName,
    );
  }
}

class ApiSportsTeamInfo {
  final String id;
  final String name;
  final String? locationName;
  final String? venueName;

  ApiSportsTeamInfo({
    required this.id,
    required this.name,
    this.locationName,
    this.venueName,
  });

  factory ApiSportsTeamInfo.fromJson(Map<String, dynamic> json) {
    return ApiSportsTeamInfo(
      id: json['id'].toString(),
      name: json['name'] as String,
      locationName: json['name']
          as String?, // API-Sports might not have separate location
      venueName: null, // API-Sports might not provide venue info
    );
  }
}

class ApiSportsService {
  static const String _baseUrl = 'v1.baseball.api-sports.io';
  static const String _apiKey = 'ac9bc3548464f0f74ab4ele76b061599';
  static const String _league =
      '1'; // MLB league ID - might need to be different
  static const String _season = '2024'; // Current season

  /// Fetches all MLB teams from API-Sports
  Future<List<ApiSportsTeamInfo>> fetchAllTeams() async {
    try {
      final url = Uri.https(_baseUrl, '/teams', {
        'league': _league,
        'season': _season,
      });

      final response = await http.get(
        url,
        headers: {
          'X-RapidAPI-Key': _apiKey,
          'X-RapidAPI-Host': _baseUrl,
        },
      );

      if (response.statusCode != 200) {
        throw Exception(
            'Team lookup failed: ${response.statusCode} - ${response.body}');
      }

      final data = jsonDecode(response.body);
      print('API-Sports response: ${response.body}');

      final teamsData = data['response'] as List<dynamic>;
      print('Teams data length: ${teamsData.length}');

      return teamsData.map((teamJson) {
        print('Processing team: $teamJson');
        return ApiSportsTeamInfo.fromJson(teamJson['team']);
      }).toList();
    } catch (e) {
      print('Error fetching teams from API-Sports: $e');
      rethrow;
    }
  }

  /// Finds a team by name (case-insensitive)
  Future<ApiSportsTeamInfo?> findTeamByName(String teamName) async {
    try {
      final teams = await fetchAllTeams();
      return teams.firstWhere(
        (team) => team.name.toLowerCase() == teamName.toLowerCase(),
        orElse: () => throw Exception('Team "$teamName" not found'),
      );
    } catch (e) {
      print('Error finding team $teamName: $e');
      return null;
    }
  }

  /// Fetches active roster for a team
  Future<List<ApiSportsPlayer>> fetchTeamRoster(String teamId) async {
    try {
      final url = Uri.https(_baseUrl, '/players', {
        'league': _league,
        'season': _season,
        'team': teamId,
      });

      final response = await http.get(
        url,
        headers: {
          'X-RapidAPI-Key': _apiKey,
          'X-RapidAPI-Host': _baseUrl,
        },
      );

      if (response.statusCode != 200) {
        throw Exception(
            'Roster fetch failed: ${response.statusCode} - ${response.body}');
      }

      final data = jsonDecode(response.body);
      final playersData = data['response'] as List<dynamic>;

      return playersData.map((playerJson) {
        return ApiSportsPlayer.fromJson(playerJson['player']);
      }).toList();
    } catch (e) {
      print('Error fetching roster for team $teamId: $e');
      rethrow;
    }
  }

  /// Fetches roster by team name (convenience method)
  Future<List<ApiSportsPlayer>> fetchRosterByTeamName(String teamName) async {
    final team = await findTeamByName(teamName);
    if (team == null) {
      throw Exception('Team "$teamName" not found');
    }
    return fetchTeamRoster(team.id);
  }

  /// Test method to verify API connection
  Future<bool> testConnection() async {
    try {
      final teams = await fetchAllTeams();
      print('API-Sports connection successful! Found ${teams.length} teams');
      return true;
    } catch (e) {
      print('API-Sports connection failed: $e');
      return false;
    }
  }
}
