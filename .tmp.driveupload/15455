  Future<void> _testPlayByPlay(String gameId) async {
    setState(() {
      _isLoading = true;
      _testResults = 'Fetching play-by-play for game $gameId...\n';
    });
    try {
      final plays = await _apiService.fetchPlayByPlay(gameId);
      setState(() {
        _testResults += 'Found ${plays.length} plays:\n\n';
        for (int i = 0; i < plays.length; i++) {
          final play = plays[i];
          final description = play['description'] ?? 'No description';
          final inning = play['inning'] ?? 'Unknown inning';
          final inningHalf = play['inning_half'] ?? 'Unknown half';
          _testResults +=
              '${i + 1}. [${inningHalf.toUpperCase()} ${inning}] $description\n';
        }
        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _testResults += 'Error: $e\n';
        _isLoading = false;
      });
    }
  }

