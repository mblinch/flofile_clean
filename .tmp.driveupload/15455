            'Found ${games.length} games on ${_selectedMonth}/${_selectedDay}/2025:\n\n';

        if (games.isEmpty) {
          _testResults += 'No games found for this date.\n';
        } else {
          for (int i = 0; i < games.length; i++) {
            final game = games[i];
            final gameDate = DateTime.parse(game.date);
            final formattedDate =
                '${gameDate.year}-${gameDate.month.toString().padLeft(2, '0')}-${gameDate.day.toString().padLeft(2, '0')}';

            _testResults += 'Game ${i + 1}:\n';
