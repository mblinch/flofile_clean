  Future<void> _testGames() async {
    setState(() {
      _isLoading = true;
      _testResults = 'Testing games API...\n';
    });

    try {
      final games = await _apiService.fetchGames();
      setState(() {
        _games = games;
        _testResults += 'Found ${games.length} games:\n\n';

        // Show first 5 games with season info
        for (int i = 0; i < games.length.clamp(0, 5); i++) {
          final game = games[i];
          _testResults += 'Game ${i + 1}:\n';
          _testResults += '  ${game.awayTeamName} @ ${game.homeTeamName}\n';
          _testResults += '  Date: ${game.date}\n';
          _testResults += '  Season: ${game.season}\n'; // Show season
          _testResults += '  Venue: ${game.venue}\n';
          _testResults += '  Status: ${game.status}\n';
          _testResults += '  Scoring Plays: ${game.scoringSummary.length}\n\n';
        }

        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _testResults += 'Error: $e';
        _isLoading = false;
      });
    }
  }

