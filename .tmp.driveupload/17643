  /// Fetches games for a specific date
  Future<List<BalldontlieGame>> fetchGamesByDate(
      String month, String day) async {
    try {
      final year = '2025';
      final date = '$year-$month-$day';

      print('Fetching games for date: $date');

      // Try different approaches to get games for the specific date
      List<BalldontlieGame> allGames = [];

      // Approach 1: Try with correct dates[] parameter
      try {
        final url1 = Uri.https(_baseUrl, '/mlb/v1/games', {
          'dates[]': date,
          'seasons[]': '2025',
        });
        print('Trying URL 1: $url1');

        final response1 =
            await http.get(url1, headers: {'Authorization': _apiKey});
        print('Response 1 status: ${response1.statusCode}');

        if (response1.statusCode == 200) {
          final data1 = jsonDecode(response1.body);
          final gamesData1 = data1['data'] as List<dynamic>;
          allGames = gamesData1
              .map((gameJson) => BalldontlieGame.fromJson(gameJson))
              .toList();
          print('URL 1 returned ${allGames.length} games');
        }
      } catch (e) {
        print('URL 1 failed: $e');
      }

      // Approach 2: Always get all games and filter client-side (since API ignores date params)
      try {
        final url2 = Uri.https(_baseUrl, '/mlb/v1/games', {
          'seasons[]': '2025',
        });
        print('Trying URL 2: $url2');

        final response2 =
            await http.get(url2, headers: {'Authorization': _apiKey});
        print('Response 2 status: ${response2.statusCode}');

        if (response2.statusCode == 200) {
          final data2 = jsonDecode(response2.body);
          final gamesData2 = data2['data'] as List<dynamic>;
          final allGames2 = gamesData2
              .map((gameJson) => BalldontlieGame.fromJson(gameJson))
              .toList();
          print('URL 2 returned ${allGames2.length} total games');

          // Filter for the specific date
          allGames = allGames2.where((game) {
            final gameDate = DateTime.parse(game.date);
            final requestedDate = DateTime.parse(date);
            return gameDate.year == requestedDate.year &&
                gameDate.month == requestedDate.month &&
                gameDate.day == requestedDate.day;
          }).toList();
          print('URL 2 filtered to ${allGames.length} games for $date');

          // Show some sample dates from the full dataset
          print('Sample dates from full dataset:');
          for (int i = 0; i < allGames2.length.clamp(0, 10); i++) {
            final game = allGames2[i];
            final gameDate = DateTime.parse(game.date);
            print(
                '  ${game.awayTeamName} @ ${game.homeTeamName} - ${gameDate.year}-${gameDate.month.toString().padLeft(2, '0')}-${gameDate.day.toString().padLeft(2, '0')}');
          }
        }
      } catch (e) {
        print('URL 2 failed: $e');
      }

      // Show all games for debugging
      if (allGames.isNotEmpty) {
        print('All games found for $date:');
        for (int i = 0; i < allGames.length; i++) {
          final game = allGames[i];
          final gameDate = DateTime.parse(game.date);
          print(
              '  ${i + 1}. ${game.awayTeamName} @ ${game.homeTeamName} - ${game.date} (${gameDate})');
        }
      } else {
        print('No games found for $date');
      }

      return allGames;
    } catch (e) {
      print('Error fetching games for date $month/$day: $e');
      rethrow;
    }
  }

