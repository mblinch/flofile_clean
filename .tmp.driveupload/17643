}

class BalldontlieGame {
  final String id;
  final String homeTeamName;
  final String awayTeamName;
  final BalldontlieTeam homeTeam;
  final BalldontlieTeam awayTeam;
  final int season;
  final bool postseason;
  final String date;
  final Map<String, dynamic> homeTeamData;
  final Map<String, dynamic> awayTeamData;
  final String venue;
  final int attendance;
  final bool conferencePlay;
  final String status;
  final int period;
  final int clock;
  final String displayClock;
  final List<BalldontlieScoringPlay> scoringSummary;

  BalldontlieGame({
    required this.id,
    required this.homeTeamName,
    required this.awayTeamName,
    required this.homeTeam,
    required this.awayTeam,
    required this.season,
    required this.postseason,
    required this.date,
    required this.homeTeamData,
    required this.awayTeamData,
    required this.venue,
    required this.attendance,
    required this.conferencePlay,
    required this.status,
    required this.period,
    required this.clock,
    required this.displayClock,
    required this.scoringSummary,
  });

  factory BalldontlieGame.fromJson(Map<String, dynamic> json) {
    final scoringSummaryData = json['scoring_summary'] as List<dynamic>? ?? [];

    return BalldontlieGame(
      id: json['id'].toString(),
      homeTeamName: json['home_team_name'] as String,
      awayTeamName: json['away_team_name'] as String,
      homeTeam: BalldontlieTeam.fromJson(json['home_team']),
      awayTeam: BalldontlieTeam.fromJson(json['away_team']),
      season: json['season'] as int,
      postseason: json['postseason'] as bool,
      date: json['date'] as String,
      homeTeamData: json['home_team_data'] as Map<String, dynamic>,
      awayTeamData: json['away_team_data'] as Map<String, dynamic>,
      venue: json['venue'] as String,
      attendance: json['attendance'] as int,
      conferencePlay: json['conference_play'] as bool,
      status: json['status'] as String,
      period: json['period'] as int,
      clock: json['clock'] as int,
      displayClock: json['display_clock'] as String,
      scoringSummary: scoringSummaryData
          .map((play) => BalldontlieScoringPlay.fromJson(play))
          .toList(),
    );
  }
}

class BalldontlieScoringPlay {
  final String play;
  final String inning;
  final String period;
  final int awayScore;
  final int homeScore;

  BalldontlieScoringPlay({
    required this.play,
    required this.inning,
    required this.period,
    required this.awayScore,
    required this.homeScore,
  });

  factory BalldontlieScoringPlay.fromJson(Map<String, dynamic> json) {
    return BalldontlieScoringPlay(
      play: json['play'] as String,
      inning: json['inning'] as String,
      period: json['period'] as String,
      awayScore: json['away_score'] as int,
      homeScore: json['home_score'] as int,
    );
  }
}

class BalldontlieApiService {
  static const String _baseUrl = 'api.balldontlie.io';
