  /// Helper to build home-run type chips + inning selector inline.
  List<Widget> _buildHomeRunOptions() {
    final hrDisplayLabels = {
      'solo': '1 Run HR',
      'two-run': '2 Run HR',
      'three-run': '3 Run HR',
      'grand slam': 'Grand Slam',
    };
    return [
      if (_selectedHomeRunType == null) ...[
        ...['solo', 'two-run', 'three-run', 'grand slam'].map((type) {
          return Padding(
            padding: const EdgeInsets.only(right: 8.0),
            child: FlashingFilterChip(
              label: SizedBox(
                width: _fixedChipWidth,
                child: Center(
                    child: Text(hrDisplayLabels[type]!,
                        style: const TextStyle(fontSize: 12))),
              ),
              selected: _selectedHomeRunType == type,
              onSelected: (_) => setState(() {
                _selectedHomeRunType =
                    _selectedHomeRunType == type ? null : type;
                _updateCaption();
              }),
              visualDensity: VisualDensity.compact,
              padding: EdgeInsets.zero,
            ),
          );
        }).toList(),
      ] else ...[
        Padding(
          padding: const EdgeInsets.only(right: 8.0),
          child: FlashingFilterChip(
            label: SizedBox(
              width: _fixedChipWidth,
              child: Center(
                  child: Text(hrDisplayLabels[_selectedHomeRunType!]!,
                      style: const TextStyle(fontSize: 12))),
            ),
            selected: true,
            showCheckmark: true,
            onSelected: (_) => setState(() {
              _selectedHomeRunType = null;
              _updateCaption();
            }),
            visualDensity: VisualDensity.compact,
            padding: EdgeInsets.zero,
          ),
        ),
      ],
      // After home run choice, always show inning selector
      _buildHitInningSelector(showWalkOffOption: true),
    ];
  }

