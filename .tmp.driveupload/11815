  void _startTypewriterEffect(String newCaption) {
    _previousCaption = captionController.text;
    _targetCaption = newCaption;
    _displayedCaption = _previousCaption; // Start with the current caption

    // If captions are identical, don't animate
    if (_previousCaption.trim() == _targetCaption.trim()) {
      captionController.text = _targetCaption;
      return;
    }

    // Calculate animation duration based on new words only
    int newWordsCount = 0;
    if (_previousCaption.isNotEmpty) {
      final oldWords =
          _previousCaption.split(' ').where((w) => w.isNotEmpty).toList();
      final newWords =
          _targetCaption.split(' ').where((w) => w.isNotEmpty).toList();

      // Find the longest common prefix of words
      int commonWords = 0;
      final minWords = min(oldWords.length, newWords.length);
      for (int i = 0; i < minWords; i++) {
        if (oldWords[i] == newWords[i]) {
          commonWords++;
        } else {
          break;
        }
      }

      // Only count truly new words (not replacements of existing words)
      newWordsCount = max(0, newWords.length - commonWords);
    } else {
      newWordsCount =
          _targetCaption.split(' ').where((w) => w.isNotEmpty).length;
    }

    // Skip animation if no new words
    if (newWordsCount == 0) {
      captionController.text = _targetCaption;
      return;
    }

    // Much faster animation: 50ms per word, minimum 150ms, maximum 400ms
    final duration =
        Duration(milliseconds: max(150, min(400, newWordsCount * 50)));

    _typewriterController.duration = duration;
    _typewriterController.reset();
    _typewriterController.forward();
  }

