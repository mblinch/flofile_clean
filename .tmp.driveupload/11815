  // Function to parse Getty IPTC template format
  void _loadGettyTemplate(String templateContent) {
    try {
      // Clear all IPTC fields first to start with a clean slate
      categoryController.clear();
      suppCat1Controller.clear();
      suppCat2Controller.clear();
      suppCat3Controller.clear();
      specialInstructionsController.clear();
      creatorController.clear();
      creatorJobTitleController.text =
          'Contributor'; // Set default instead of clearing
      cityController.clear();
      stadiumController.clear();
      provinceController.clear();
      countryCodeController.text = 'CAN'; // Set default instead of clearing
      countryController.text = 'Canada'; // Set default instead of clearing
      jobIdController.clear();
      headlineController.clear();
      creditController.clear();
      sourceController.clear();
      copyrightController.clear();
      captionController.clear();

      final lines = templateContent.split('\n');
      print('Template loaded with ${lines.length} lines'); // Debug info

      for (String line in lines) {
        if (line.trim().isEmpty) continue;

        // Split only the first three colons
        final firstColon = line.indexOf(':');
        final secondColon = line.indexOf(':', firstColon + 1);
        final thirdColon = line.indexOf(':', secondColon + 1);
        if (firstColon == -1 || secondColon == -1 || thirdColon == -1) {
          print('Skipping invalid line: $line');
          continue;
        }
        final fieldCode = line.substring(0, secondColon);
        final length =
            int.tryParse(line.substring(secondColon + 1, thirdColon)) ?? 0;
        final value = line.substring(thirdColon + 1).trim();

        print('Processing field: $fieldCode = $value'); // Debug info

        switch (fieldCode) {
          case '2:15': // Category
            categoryController.text = value;
            break;
          case '2:20': // Supplemental Categories
            // Handle multiple supplemental categories
            if (suppCat1Controller.text.isEmpty) {
              suppCat1Controller.text = value;
            } else if (suppCat2Controller.text.isEmpty) {
              suppCat2Controller.text = value;
            } else if (suppCat3Controller.text.isEmpty) {
              suppCat3Controller.text = value;
            }
            break;
          case '2:40': // Special Instructions
            specialInstructionsController.text = value;
            break;
          case '2:55': // Date
            try {
              // Parse date format YYYYMMDD
              if (value.length >= 8) {
                final year = int.parse(value.substring(0, 4));
                final month = int.parse(value.substring(4, 6));
                final day = int.parse(value.substring(6, 8));
                selectedDate = DateTime(year, month, day);
              } else {
                print('Date value too short: $value');
              }
            } catch (e) {
              print('Error parsing date: $value - $e'); // Debug info
              // Keep current date if parsing fails
            }
            break;
          case '2:80': // Creator
            creatorController.text = value;
            break;
          case '2:85': // Creator Job Title
            // Check if the value is a valid job title option
            final validJobTitles = ['Contributor', 'Stringer', 'Staff'];
            if (validJobTitles.contains(value)) {
              creatorJobTitleController.text = value;
            } else {
              // Default to 'Contributor' if the value is not valid
              creatorJobTitleController.text = 'Contributor';
            }
            break;
          case '2:90': // City
            cityController.text = value;
            break;
          case '2:92': // Sub-location/Stadium
            stadiumController.text = value;
            break;
          case '2:95': // Province/State
            provinceController.text = value;
            break;
          case '2:100': // Country Code
            countryCodeController.text = value;
            break;
          case '2:101': // Country
            countryController.text = value;
            break;
          case '2:103': // Transmission Reference (Job ID/MEID)
            jobIdController.text = value;
            break;
          case '2:105': // Headline
            headlineController.text = value;
            break;
          case '2:110': // Credit
            creditController.text = value;
            break;
          case '2:115': // Source
            sourceController.text = value;
            break;
          case '2:116': // Copyright
            copyrightController.text = value;
            break;
          case '2:120': // Caption template
            // Extract the caption part from the template
            if (value.contains('<<enter caption here>>')) {
              final captionTemplate =
                  value.replaceAll('<<enter caption here>>', '');
              captionController.text = captionTemplate;
            }
            break;
          default:
            print('Unknown field code: $fieldCode'); // Debug info
            break;
        }
      }

      // Update Object Name after loading template
      _updateObjectName();
      _updateCaption();

      print('Template loading completed successfully'); // Debug info
    } catch (e) {
      print('Error in _loadGettyTemplate: $e'); // Debug info
      rethrow; // Re-throw the error so it can be caught by the calling function
    }
  }

  // Function to show file picker and load template
  Future<void> _loadTemplateFromFile() async {
    try {
      final result = await FilePicker.platform.pickFiles(
        type: FileType.custom,
        allowedExtensions: ['txt'],
        allowMultiple: false,
      );

      if (result != null && result.files.isNotEmpty) {
        final file = File(result.files.first.path!);
        final content = await file.readAsString();

        setState(() {
          _loadGettyTemplate(content);
        });

        // Show success message
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Getty template loaded successfully'),
            backgroundColor: Colors.green,
          ),
        );
      }
    } catch (e) {
      // Show error message
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Error loading template: $e'),
          backgroundColor: Colors.red,
        ),
      );
    }
  }
