  Future<void> pickCodeFile() async {
    final result = await FilePicker.platform.pickFiles();
    if (result?.files.single.path == null) return;
    final path = result!.files.single.path!;
    final lines = await File(path).readAsLines();
    for (var line in lines) {
      if (line.trim().isEmpty) continue;
      final parts = line.split('\t');
      if (parts.length >= 2) {
        final code = parts[0];
        final full = parts[1];
        final short = parts.length > 2 ? parts[2] : full;
        final first = parts.length > 3 ? parts[3] : '';
        codeReplacements[code] = Replacement(full, short, first);
      }
    }
    setState(() {
      selectedPlayers.clear();
      selectedOpponentPlayers.clear(); // Clear opponent players too
      _selectedVerb = null;
      selectedInning = null;
      celebrateWith.clear();
    });
    _updateCaption();
  }

