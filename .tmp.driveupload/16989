import 'package:flutter/material.dart';
import '../services/balldontlie_api_service.dart';

class CalendarWidget extends StatefulWidget {
  const CalendarWidget({super.key});

  @override
  State<CalendarWidget> createState() => _CalendarWidgetState();
}

class _CalendarWidgetState extends State<CalendarWidget> {
  final BalldontlieApiService _apiService = BalldontlieApiService();
  DateTime _selectedDate = DateTime.now();
  DateTime _focusedDate = DateTime.now();
  List<BalldontlieGame> _gamesForSelectedDate = [];
  bool _isLoading = false;
  String _selectedDateString = '';

  @override
  void initState() {
    super.initState();
    _loadGamesForDate(_selectedDate);
  }

  Future<void> _loadGamesForDate(DateTime date) async {
    setState(() {
      _isLoading = true;
      _selectedDate = date;
      _selectedDateString =
          '${date.year}-${date.month.toString().padLeft(2, '0')}-${date.day.toString().padLeft(2, '0')}';
    });

    try {
      final games = await _apiService.fetchGamesForDate(_selectedDateString);
      setState(() {
        _gamesForSelectedDate = games;
        _isLoading = false;
      });
    } catch (e) {
      setState(() {
        _gamesForSelectedDate = [];
        _isLoading = false;
      });
      print('Error loading games for $date: $e');
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('MLB Games Calendar'),
        backgroundColor: Colors.blue.shade700,
        foregroundColor: Colors.white,
      ),
      body: Column(
        children: [
          // Calendar
          Container(
            padding: const EdgeInsets.all(16),
            child: TableCalendar<BalldontlieGame>(
              firstDay: DateTime(2025, 1, 1),
              lastDay: DateTime(2025, 12, 31),
              focusedDay: _focusedDate,
              selectedDayPredicate: (day) => isSameDay(_selectedDate, day),
              calendarFormat: CalendarFormat.month,
              eventLoader: (day) {
                // This would load events for each day, but we'll load on demand
                return [];
              },
              onDaySelected: (selectedDay, focusedDay) {
                setState(() {
                  _focusedDate = focusedDay;
                });
                _loadGamesForDate(selectedDay);
              },
              onPageChanged: (focusedDay) {
                setState(() {
                  _focusedDate = focusedDay;
                });
              },
              calendarStyle: const CalendarStyle(
                selectedDecoration: BoxDecoration(
                  color: Colors.blue,
                  shape: BoxShape.circle,
                ),
                todayDecoration: BoxDecoration(
                  color: Colors.orange,
                  shape: BoxShape.circle,
                ),
                markerDecoration: BoxDecoration(
                  color: Colors.red,
                  shape: BoxShape.circle,
                ),
              ),
            ),
          ),

          // Selected date and games
          Container(
            padding: const EdgeInsets.all(16),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Games for ${_selectedDateString}',
                  style: const TextStyle(
                    fontSize: 18,
                    fontWeight: FontWeight.bold,
                  ),
                ),
                const SizedBox(height: 8),
                if (_isLoading)
                  const Center(child: CircularProgressIndicator())
                else if (_gamesForSelectedDate.isEmpty)
                  const Text('No games scheduled for this date')
                else
                  Expanded(
                    child: ListView.builder(
                      itemCount: _gamesForSelectedDate.length,
                      itemBuilder: (context, index) {
                        final game = _gamesForSelectedDate[index];
                        return Card(
                          margin: const EdgeInsets.symmetric(vertical: 4),
                          child: ListTile(
                            title: Text(
                              '${game.awayTeamName} @ ${game.homeTeamName}',
                              style:
                                  const TextStyle(fontWeight: FontWeight.bold),
                            ),
                            subtitle: Column(
                              crossAxisAlignment: CrossAxisAlignment.start,
                              children: [
                                Text('Venue: ${game.venue}'),
                                Text('Status: ${game.status}'),
                                if (game.status.contains('FINAL'))
                                  Text(
                                      'Final Score: ${game.awayTeamData['runs']} - ${game.homeTeamData['runs']}'),
                              ],
                            ),
                            trailing: IconButton(
                              icon: const Icon(Icons.info),
                              onPressed: () => _showGameDetails(game),
                            ),
                          ),
                        );
                      },
                    ),
                  ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  void _showGameDetails(BalldontlieGame game) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text('${game.awayTeamName} @ ${game.homeTeamName}'),
        content: SingleChildScrollView(
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            mainAxisSize: MainAxisSize.min,
            children: [
              Text('Date: ${game.date}'),
              Text('Venue: ${game.venue}'),
              Text('Status: ${game.status}'),
              Text('Attendance: ${game.attendance}'),
              if (game.status.contains('FINAL')) ...[
                const SizedBox(height: 8),
                Text(
                    'Final Score: ${game.awayTeamData['runs']} - ${game.homeTeamData['runs']}'),
              ],
              if (game.scoringSummary.isNotEmpty) ...[
                const SizedBox(height: 8),
                const Text('Scoring Plays:',
                    style: TextStyle(fontWeight: FontWeight.bold)),
                const SizedBox(height: 4),
                ...game.scoringSummary.take(5).map((play) => Text(
                      '• ${play.period} ${play.inning}: ${play.play}',
                      style: const TextStyle(fontSize: 12),
                    )),
                if (game.scoringSummary.length > 5)
                  Text('... and ${game.scoringSummary.length - 5} more plays'),
              ],
            ],
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Close'),
          ),
        ],
      ),
    );
  }
}

// Helper function for calendar
bool isSameDay(DateTime a, DateTime b) {
  return a.year == b.year && a.month == b.month && a.day == b.day;
}

// Simple calendar widget (since we don't have table_calendar package)
class TableCalendar<T> extends StatefulWidget {
  final DateTime firstDay;
  final DateTime lastDay;
  final DateTime focusedDay;
  final DateTime? selectedDay;
  final List<T> Function(DateTime) eventLoader;
  final void Function(DateTime, DateTime) onDaySelected;
  final void Function(DateTime) onPageChanged;
  final CalendarStyle calendarStyle;
  final CalendarFormat calendarFormat;

  const TableCalendar({
    super.key,
    required this.firstDay,
    required this.lastDay,
    required this.focusedDay,
    this.selectedDay,
    required this.eventLoader,
    required this.onDaySelected,
    required this.onPageChanged,
    required this.calendarStyle,
    required this.calendarFormat,
  });

  @override
  State<TableCalendar<T>> createState() => _TableCalendarState<T>();
}

class _TableCalendarState<T> extends State<TableCalendar<T>> {
  late DateTime _focusedDay;
  late DateTime _selectedDay;

  @override
  void initState() {
    super.initState();
    _focusedDay = widget.focusedDay;
    _selectedDay = widget.selectedDay ?? widget.focusedDay;
  }

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        // Month/Year header
        Row(
          mainAxisAlignment: MainAxisAlignment.spaceBetween,
          children: [
            IconButton(
              icon: const Icon(Icons.chevron_left),
              onPressed: () => _previousMonth(),
            ),
            Text(
              '${_getMonthName(_focusedDay.month)} ${_focusedDay.year}',
              style: const TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
            ),
            IconButton(
              icon: const Icon(Icons.chevron_right),
              onPressed: () => _nextMonth(),
            ),
          ],
        ),
        const SizedBox(height: 16),

        // Calendar grid
        _buildCalendarGrid(),
      ],
    );
  }

  Widget _buildCalendarGrid() {
    final daysInMonth =
        DateTime(_focusedDay.year, _focusedDay.month + 1, 0).day;
    final firstDayOfMonth = DateTime(_focusedDay.year, _focusedDay.month, 1);
    final firstWeekday = firstDayOfMonth.weekday;

    final List<Widget> calendarDays = [];

    // Add day headers
    const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    for (final dayName in dayNames) {
      calendarDays.add(
        Container(
          padding: const EdgeInsets.all(8),
          child: Text(
            dayName,
            textAlign: TextAlign.center,
            style: const TextStyle(fontWeight: FontWeight.bold),
          ),
        ),
      );
    }

    // Add empty cells for days before the first day of the month
    for (int i = 1; i < firstWeekday; i++) {
      calendarDays.add(const SizedBox(height: 40));
    }

    // Add days of the month
    for (int day = 1; day <= daysInMonth; day++) {
      final date = DateTime(_focusedDay.year, _focusedDay.month, day);
      final isSelected = isSameDay(date, _selectedDay);
      final isToday = isSameDay(date, DateTime.now());

      calendarDays.add(
        GestureDetector(
          onTap: () => _onDaySelected(date),
          child: Container(
            height: 40,
            margin: const EdgeInsets.all(2),
            decoration: BoxDecoration(
              color: isSelected
                  ? widget.calendarStyle.selectedDecoration.color
                  : null,
              shape: BoxShape.circle,
            ),
            child: Center(
              child: Text(
                day.toString(),
                style: TextStyle(
                  color: isSelected
                      ? Colors.white
                      : (isToday ? Colors.orange : Colors.black),
                  fontWeight: isSelected || isToday
                      ? FontWeight.bold
                      : FontWeight.normal,
                ),
              ),
            ),
          ),
        ),
      );
    }

    return GridView.count(
      shrinkWrap: true,
      crossAxisCount: 7,
      children: calendarDays,
    );
  }

  void _onDaySelected(DateTime day) {
    setState(() {
      _selectedDay = day;
    });
    widget.onDaySelected(day, _focusedDay);
  }

  void _previousMonth() {
    final newFocusedDay = DateTime(_focusedDay.year, _focusedDay.month - 1);
    if (newFocusedDay.isAfter(widget.firstDay) ||
        newFocusedDay.isAtSameMomentAs(widget.firstDay)) {
      setState(() {
        _focusedDay = newFocusedDay;
      });
      widget.onPageChanged(newFocusedDay);
    }
  }

  void _nextMonth() {
    final newFocusedDay = DateTime(_focusedDay.year, _focusedDay.month + 1);
    if (newFocusedDay.isBefore(widget.lastDay) ||
        newFocusedDay.isAtSameMomentAs(widget.lastDay)) {
      setState(() {
        _focusedDay = newFocusedDay;
      });
      widget.onPageChanged(newFocusedDay);
    }
  }

  String _getMonthName(int month) {
    const monthNames = [
      'January',
      'February',
      'March',
      'April',
      'May',
      'June',
      'July',
      'August',
      'September',
      'October',
      'November',
      'December'
    ];
    return monthNames[month - 1];
  }
}
