  /// Fetches games data
  Future<List<BalldontlieGame>> fetchGames() async {
    try {
      // Try different season parameter formats
      final url = Uri.https(_baseUrl, '/mlb/v1/games', {
        'seasons[]': '2025', // Try array format
      });

      print('Full API URL for all games: $url');

      final response = await http.get(
        url,
        headers: {'Authorization': _apiKey},
      );

      print('All games response status: ${response.statusCode}');

      if (response.statusCode != 200) {
        throw Exception('Games lookup failed: ${response.statusCode}');
      }

      final data = jsonDecode(response.body);
      final gamesData = data['data'] as List<dynamic>;

      print('Found ${gamesData.length} total games in API response');

      final allGames = gamesData
          .map((gameJson) => BalldontlieGame.fromJson(gameJson))
          .toList();

      // Filter for 2025 games only
      final games = allGames.where((game) => game.season == 2025).toList();

      print('Found ${allGames.length} total games, ${games.length} from 2025');

      // Print first game info for debugging
      if (games.isNotEmpty) {
        print('First 2025 game season: ${games.first.season}');
        print('First 2025 game date: ${games.first.date}');
      }

      return games;
    } catch (e) {
      print('Error fetching games: $e');
      rethrow;
    }
  }

  /// Fetches games from the past week
  Future<List<BalldontlieGame>> fetchRecentGames() async {
    try {
      // Calculate dates for past week
      final now = DateTime.now();
      final oneWeekAgo = now.subtract(const Duration(days: 7));

      // Format dates as YYYY-MM-DD
      final endDate =
          '${now.year}-${now.month.toString().padLeft(2, '0')}-${now.day.toString().padLeft(2, '0')}';
      final startDate =
          '${oneWeekAgo.year}-${oneWeekAgo.month.toString().padLeft(2, '0')}-${oneWeekAgo.day.toString().padLeft(2, '0')}';

      print('Fetching games from $startDate to $endDate for 2025 season');

      final url = Uri.https(_baseUrl, '/mlb/v1/games', {
        'start_date': startDate,
        'end_date': endDate,
        'seasons[]': '2025', // Try array format
      });

      print('Full API URL: $url');

      final response = await http.get(
        url,
        headers: {'Authorization': _apiKey},
      );

      print('Response status: ${response.statusCode}');
      print(
          'Response body preview: ${response.body.substring(0, response.body.length.clamp(0, 200))}...');

      if (response.statusCode != 200) {
        throw Exception('Recent games lookup failed: ${response.statusCode}');
      }

      final data = jsonDecode(response.body);
      final gamesData = data['data'] as List<dynamic>;

      print('Found ${gamesData.length} games in API response');

      final allGames = gamesData
          .map((gameJson) => BalldontlieGame.fromJson(gameJson))
          .toList();

      // Filter for 2025 games only
      final games = allGames.where((game) => game.season == 2025).toList();

      print('Found ${allGames.length} total games, ${games.length} from 2025');

      // Print first game info for debugging
      if (games.isNotEmpty) {
        print('First 2025 game season: ${games.first.season}');
        print('First 2025 game date: ${games.first.date}');
      }

      // Sort by date (most recent first)
      games.sort((a, b) => b.date.compareTo(a.date));

      return games;
    } catch (e) {
      print('Error fetching recent games: $e');
      rethrow;
    }
  }

  /// Fetches a specific game by ID
  Future<BalldontlieGame?> fetchGameById(String gameId) async {
    try {
      final url = Uri.https(_baseUrl, '/mlb/v1/games/$gameId');
      final response = await http.get(
        url,
        headers: {'Authorization': _apiKey},
      );

      if (response.statusCode != 200) {
        throw Exception('Game lookup failed: ${response.statusCode}');
      }

      final data = jsonDecode(response.body);
      return BalldontlieGame.fromJson(data['data']);
    } catch (e) {
      print('Error fetching game $gameId: $e');
      rethrow;
    }
  }
}
