  // Optimize cache by keeping only nearby images
  void _optimizeCache() {
    if (imagePaths.isEmpty) return;

    final keepIndices = <int>{};
    // Keep current image and more adjacent images for better performance
    for (int i = -3; i <= 3; i++) {
      final index = currentIndex + i;
      if (index >= 0 && index < imagePaths.length) {
        keepIndices.add(index);
      }
    }

    final pathsToKeep = keepIndices.map((i) => imagePaths[i]).toSet();

    // Only clear full image cache, keep more thumbnails for better performance
    _imageCache.removeWhere((path, _) => !pathsToKeep.contains(path));

    // Keep more thumbnails in cache for smoother navigation
    // Only clear thumbnails that are far from current position
    if (_thumbnailCache.length > 200) {
      // Only optimize if cache is getting large
      final farIndices = <int>{};
      for (int i = 0; i < imagePaths.length; i++) {
        if ((i - currentIndex).abs() > 50) {
          // Keep thumbnails within 50 images
          farIndices.add(i);
        }
      }
      final farPaths = farIndices.map((i) => imagePaths[i]).toSet();
      _thumbnailCache.removeWhere((path, _) => farPaths.contains(path));
    }
  }

