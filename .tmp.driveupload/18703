  Widget _buildFullResImage(String imagePath) {
    return FutureBuilder<Uint8List?>(
      future: _loadImageBytes(imagePath),
      builder: (context, snapshot) {
        if (snapshot.connectionState == ConnectionState.waiting) {
          // Show medium-res preview while full-res loads
          return FutureBuilder<Uint8List?>(
            future: _loadMediumResPreview(imagePath),
            builder: (context, mediumSnapshot) {
              if (mediumSnapshot.hasData) {
                return Stack(
                  children: [
                    Image.memory(
                      mediumSnapshot.data!,
                      fit: BoxFit.contain,
                    ),
                    const Positioned(
                      top: 16,
                      right: 16,
                      child: CircularProgressIndicator(
                        backgroundColor: Colors.white,
                      ),
                    ),
                  ],
                );
              }
              return Container(
                color: Colors.grey.shade200,
                child: const Center(
                  child: CircularProgressIndicator(),
                ),
              );
            },
          );
        }

        if (snapshot.hasError || !snapshot.hasData) {
          return Container(
            color: Colors.grey.shade200,
            child: const Center(
              child: Icon(Icons.error, color: Colors.grey),
            ),
          );
        }

        return Image.memory(
          snapshot.data!,
          fit: BoxFit.contain,
        );
      },
    );
  }

