  // Preload images with priority (current + adjacent first)
  void _preloadWithPriority() {
    if (imagePaths.isEmpty) return;

    // Priority 1: Current image (medium-res preview)
    _loadMediumResPreview(imagePaths[currentIndex]);

    // Priority 2: Adjacent images (medium-res previews)
    for (int i = -2; i <= 2; i++) {
      final index = currentIndex + i;
      if (index >= 0 && index < imagePaths.length && index != currentIndex) {
        _loadMediumResPreview(imagePaths[index]);
      }
    }

    // Priority 3: Thumbnails for current and adjacent images
    for (int i = -1; i <= 1; i++) {
      final index = currentIndex + i;
      if (index >= 0 && index < imagePaths.length) {
        _loadThumbnailBytes(imagePaths[index], maxSize: 300);
      }
    }

    // Priority 4: Visible thumbnails (low quality)
    _preloadVisibleThumbnails();
  }

  // Start preloading visible thumbnails immediately
  void _startVisibleThumbnailPreload() {
    if (imagePaths.isNotEmpty) {
      // Use a small delay to ensure the filmstrip is built
      Future.delayed(const Duration(milliseconds: 100), () {
        if (mounted) {
          _preloadVisibleThumbnails();
        }
      });
    }
  }

  // Preload visible thumbnails in filmstrip
  void _preloadVisibleThumbnails() {
    if (imagePaths.isEmpty || !_filmstripController.hasClients) return;

    final scrollOffset = _filmstripController.offset;
    final viewportWidth = _filmstripController.position.viewportDimension;
    const double filmstripHeight = 140.0;
    const double imagePadding = 4.0;
    const double imageWidth =
        filmstripHeight - (imagePadding * 2) + (imagePadding * 2);

    // Calculate visible range
    final startIndex = (scrollOffset / imageWidth).floor();
    final endIndex = ((scrollOffset + viewportWidth) / imageWidth).ceil();

    // Preload visible thumbnails
    for (int i = startIndex; i <= endIndex && i < imagePaths.length; i++) {
      if (i >= 0 && !_thumbnailCache.containsKey(imagePaths[i])) {
        _loadThumbnailBytes(imagePaths[i]);
      }
    }
  }

