  // Update nextImage
  Future<void> nextImage() async {
    if (currentIndex < imagePaths.length - 1) {
      // Store current caption as previous before saving and resetting
      _previousCaptionText = captionController.text;
      _previousPersonalityText = personalityController.text;

      await _saveCaptionToFile(imagePaths[currentIndex]);
      _resetCaption();
      setState(() {
        currentIndex++;
        _updateCurrentImageFuture();
      });
      _scrollToSelectedImage();
      await _loadMetadata();
      _preloadWithPriority(); // Use priority preload (current + adjacent)
      _optimizeCache(); // Optimize cache to prevent memory issues

      // Check if current image is part of a time group after navigation
      _checkTimeGroup();
    }
  }

  // Update previousImage
  Future<void> previousImage() async {
    if (currentIndex > 0) {
      // Store current caption as previous before saving and resetting
      _previousCaptionText = captionController.text;
      _previousPersonalityText = personalityController.text;

      await _saveCaptionToFile(imagePaths[currentIndex]);
      _resetCaption();
      setState(() {
        currentIndex--;
        _updateCurrentImageFuture();
      });
      _scrollToSelectedImage();
      await _loadMetadata();
      _preloadWithPriority(); // Use priority preload (current + adjacent)
      _optimizeCache(); // Optimize cache to prevent memory issues

      // Check if current image is part of a time group after navigation
      _checkTimeGroup();
    }
  }

  // Update _selectImage
  Future<void> _selectImage(int index) async {
    if (index < 0 || index >= imagePaths.length || index == currentIndex) {
      return;
    }
    // Save the current caption before switching
    if (imagePaths.isNotEmpty) {
      await _saveCaptionToFile(imagePaths[currentIndex]);
    }
    setState(() {
      currentIndex = index;
      _updateCurrentImageFuture();
    });
    _scrollToSelectedImage();
    await _loadMetadata();
    _preloadWithPriority(); // Use priority preload (current + adjacent)
    _optimizeCache(); // Optimize cache to prevent memory issues

    // Check if current image is part of a time group after navigation
    _checkTimeGroup();
  }

