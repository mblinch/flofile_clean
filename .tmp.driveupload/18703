  // Group images by time (same second) and lens for burst shots
  Future<void> _groupImagesByTime() async {
    if (imagePaths.isEmpty) return;

    _timeGroups.clear();
    final Map<String, List<int>> tempGroups = {};

    for (int i = 0; i < imagePaths.length; i++) {
      try {
        final proc = await Process.run(
          'exiftool',
          ['-j', '-DateTimeOriginal', '-LensID', imagePaths[i]],
        );

        if (proc.exitCode == 0) {
          final List data = jsonDecode(proc.stdout as String);
          if (data.isNotEmpty) {
            final meta = data.first as Map<String, dynamic>;
            final dateTimeString = meta['DateTimeOriginal']?.toString();
            final lensId = meta['LensID']?.toString() ?? 'Unknown';

            if (dateTimeString != null) {
              // Parse the date and get the second-level timestamp
              final dt = DateTime.parse(
                  dateTimeString.replaceFirst(':', '-').replaceFirst(':', '-'));
              final timeKey =
                  '${dt.year}-${dt.month.toString().padLeft(2, '0')}-${dt.day.toString().padLeft(2, '0')} ${dt.hour.toString().padLeft(2, '0')}:${dt.minute.toString().padLeft(2, '0')}:${dt.second.toString().padLeft(2, '0')}';

              // Create a combined key with time and lens
              final combinedKey = '$timeKey|$lensId';

              if (!tempGroups.containsKey(combinedKey)) {
                tempGroups[combinedKey] = [];
              }
              tempGroups[combinedKey]!.add(i);
            }
          }
        }
      } catch (e) {
        print('Error getting time/lens for image $i: $e');
      }
    }

    // Only keep groups with more than one image (actual bursts)
    _timeGroups = Map.fromEntries(
        tempGroups.entries.where((entry) => entry.value.length > 1));

    print('Time+Lens groups found: ${_timeGroups.length}');
    _timeGroups.forEach((combinedKey, indices) {
      final parts = combinedKey.split('|');
      final time = parts[0];
      final lens = parts.length > 1 ? parts[1] : 'Unknown';
      print(
          'Time $time, Lens $lens: ${indices.length} images (indices: $indices)');
    });
  }

