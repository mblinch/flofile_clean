  Widget _buildProgressiveImage(String imagePath,
      {double? width, double? height, BoxFit fit = BoxFit.contain}) {
    return FutureBuilder<Uint8List?>(
      future: _loadMediumResPreview(imagePath),
      builder: (context, mediumSnapshot) {
        // Show thumbnail immediately if available, or loading indicator
        Widget thumbnailWidget = FutureBuilder<Uint8List?>(
          future: _loadThumbnailBytes(imagePath, maxSize: 300),
          builder: (context, thumbSnapshot) {
            if (thumbSnapshot.hasData) {
              return Image.memory(
                thumbSnapshot.data!,
                width: width,
                height: height,
                fit: fit,
              );
            }
            return Container(
              width: width,
              height: height,
              color: Colors.grey.shade200,
              child: const Center(
                child: CircularProgressIndicator(),
              ),
            );
          },
        );

        // If medium-res preview is available, show it; otherwise show thumbnail
        if (mediumSnapshot.connectionState == ConnectionState.done) {
          if (mediumSnapshot.hasData) {
            return Image.memory(
              mediumSnapshot.data!,
              width: width,
              height: height,
              fit: fit,
            );
          } else if (mediumSnapshot.hasError) {
            // Fallback to full-res if medium-res fails
            return FutureBuilder<Uint8List?>(
              future: _loadImageBytes(imagePath),
              builder: (context, fullSnapshot) {
                if (fullSnapshot.hasData) {
                  return Image.memory(
                    fullSnapshot.data!,
                    width: width,
                    height: height,
                    fit: fit,
                  );
                }
                return thumbnailWidget;
              },
            );
          }
        }

        // Show thumbnail while medium-res is loading
        return thumbnailWidget;
      },
    );
  }

  // Add to state:
  final Map<String, Future<Uint8List?>> _thumbnailFutures = {};

  Future<Uint8List?> _getThumbnailFuture(String imagePath) {
    return _thumbnailFutures.putIfAbsent(
        imagePath, () => _loadThumbnailBytes(imagePath));
  }

  // In the filmstrip thumbnail widget, replace:
  // FutureBuilder<Uint8List?>(
  //   future: _loadThumbnailBytes(imagePaths[index]),
  //   ...
  // )
  // with:
  // FutureBuilder<Uint8List?>(
  //   future: _getThumbnailFuture(imagePaths[index]),
  //   ...
