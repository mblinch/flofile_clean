  void _sortByName() {
    // Natural sort for filenames (handles numbers correctly)
    imagePaths.sort((a, b) {
      final fileNameA = p.basename(a);
      final fileNameB = p.basename(b);

      // Simple natural sort implementation
      return _naturalCompare(fileNameA, fileNameB);
    });
  }

  int _naturalCompare(String a, String b) {
    // Split strings into parts (numbers and non-numbers)
    final partsA = _splitIntoParts(a);
    final partsB = _splitIntoParts(b);

    final minLength =
        partsA.length < partsB.length ? partsA.length : partsB.length;

    for (int i = 0; i < minLength; i++) {
      final partA = partsA[i];
      final partB = partsB[i];

      if (partA.isNumber && partB.isNumber) {
        // Compare as numbers
        final numA = int.parse(partA.text);
        final numB = int.parse(partB.text);
        if (numA != numB) return numA.compareTo(numB);
      } else {
        // Compare as strings (case-insensitive)
        final comparison =
            partA.text.toLowerCase().compareTo(partB.text.toLowerCase());
        if (comparison != 0) return comparison;
      }
    }

    // If all parts match up to minLength, shorter string comes first
    return partsA.length.compareTo(partsB.length);
  }

  List<_SortPart> _splitIntoParts(String str) {
    final parts = <_SortPart>[];
    final buffer = StringBuffer();
    bool? isNumber;

    for (int i = 0; i < str.length; i++) {
      final char = str[i];
      final charIsDigit = char.codeUnitAt(0) >= 48 && char.codeUnitAt(0) <= 57;

      if (isNumber == null) {
        isNumber = charIsDigit;
        buffer.write(char);
      } else if (charIsDigit == isNumber) {
        buffer.write(char);
      } else {
        if (buffer.isNotEmpty) {
          parts.add(_SortPart(buffer.toString(), isNumber));
          buffer.clear();
        }
        isNumber = charIsDigit;
        buffer.write(char);
      }
    }

    if (buffer.isNotEmpty) {
      parts.add(_SortPart(buffer.toString(), isNumber!));
    }

    return parts;
  }

  void _sortByDate(bool ascending) {
    imagePaths.sort((a, b) {
      try {
        final fileA = File(a);
        final fileB = File(b);

        if (!fileA.existsSync() || !fileB.existsSync()) {
          // If files don't exist, fall back to name sorting
          return _naturalCompare(p.basename(a), p.basename(b));
        }

        final statA = fileA.statSync();
        final statB = fileB.statSync();

        if (ascending) {
          return statA.modified.compareTo(statB.modified);
        } else {
          return statB.modified.compareTo(statA.modified);
        }
      } catch (e) {
        // If there's an error accessing file stats, fall back to name sorting
        return _naturalCompare(p.basename(a), p.basename(b));
      }
    });
  }

  Future<void> _sortByCamera() async {
    if (imagePaths.isEmpty) return;

    final currentImagePath = imagePaths[currentIndex];

    try {
      final List<MapEntry<String, String>> filesWithSerial = [];
      final List<String> filesWithoutSerial = [];

      for (final path in imagePaths) {
        final serial = await _getCameraSerialNumber(path);
        if (serial != null) {
          filesWithSerial.add(MapEntry(path, serial));
        } else {
          filesWithoutSerial.add(path);
        }
      }

      // Sort files with serial numbers alphabetically
      filesWithSerial.sort((a, b) => a.value.compareTo(b.value));

      // Combine sorted files with serial numbers first, then files without
      final sortedPaths = [
        ...filesWithSerial.map((e) => e.key),
        ...filesWithoutSerial,
      ];

      setState(() {
        imagePaths.clear();
        imagePaths.addAll(sortedPaths);
      });

      // Find the current image in the new sorted list
      final newIndex = imagePaths.indexOf(currentImagePath);
      if (newIndex != -1 && newIndex != currentIndex) {
        setState(() {
          currentIndex = newIndex;
        });
      }
    } catch (e) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Error sorting by camera: $e'),
          backgroundColor: Colors.red,
        ),
      );
    }
  }

  Future<String?> _getCameraSerialNumber(String imagePath) async {
    try {
      final result =
          await Process.run('exiftool', ['-SerialNumber', '-n', imagePath]);
      if (result.exitCode == 0 && result.stdout.toString().trim().isNotEmpty) {
        return result.stdout.toString().trim();
      }
      return null;
    } catch (e) {
      return null;
    }
  }

  // Optimized image loading functions
  Future<Uint8List?> _loadImageBytes(String imagePath) async {
    if (_imageCache.containsKey(imagePath)) {
      return _imageCache[imagePath];
    }

    try {
      final file = File(imagePath);
      if (await file.exists()) {
        final bytes = await file.readAsBytes();
        _imageCache[imagePath] = bytes;
        return bytes;
      }
    } catch (e) {
      print('Error loading image: $e');
    }
    return null;
  }

  Future<Uint8List?> _loadThumbnailBytes(String imagePath,
      {int maxSize = 200}) async {
    if (_thumbnailCache.containsKey(imagePath)) {
      return _thumbnailCache[imagePath];
    }

    try {
      final originalBytes = await _loadImageBytes(imagePath);
      if (originalBytes != null) {
        // Create a properly sized thumbnail for faster loading
        final thumbnailBytes = await _createThumbnail(originalBytes, maxSize);
        _thumbnailCache[imagePath] = thumbnailBytes;
        return thumbnailBytes;
      }
    } catch (e) {
      print('Error loading thumbnail: $e');
    }
    return null;
  }

  // Directory for medium-res previews
  final String _previewCacheDir =
      '${Directory.systemTemp.path}/caption_writer_previews';

  Future<Uint8List?> _loadMediumResPreview(String imagePath,
      {int maxWidth = 1080}) async {
    // Check memory cache first
    if (_previewCache.containsKey(imagePath)) {
      return _previewCache[imagePath];
    }

    final fileName = p.basename(imagePath);
    final previewPath = '$_previewCacheDir/$fileName.preview.jpg';
    final previewFile = File(previewPath);

    // Check disk cache
    if (await previewFile.exists()) {
      final bytes = await previewFile.readAsBytes();
      _previewCache[imagePath] = bytes;
      return bytes;
    }

    // Generate medium-res preview
    try {
      final originalBytes = await _loadImageBytes(imagePath);
      if (originalBytes == null) return null;
      final image = img.decodeImage(originalBytes);
      if (image == null) return null;
      final resized = img.copyResize(image, width: maxWidth);
      final jpg = img.encodeJpg(resized, quality: 85);
      final previewBytes = Uint8List.fromList(jpg);

      // Cache in memory and disk
      _previewCache[imagePath] = previewBytes;

      // Ensure cache directory exists and save to disk
      await Directory(_previewCacheDir).create(recursive: true);
      await previewFile.writeAsBytes(jpg, flush: true);

      return previewBytes;
    } catch (e) {
      print('Error generating medium-res preview: $e');
      return null;
    }
  }

  // Create a thumbnail from image bytes
  Future<Uint8List> _createThumbnail(
      Uint8List originalBytes, int maxSize) async {
    try {
      // Use Flutter's image package to resize
      final codec = await ui.instantiateImageCodec(
        originalBytes,
        targetWidth: maxSize,
        targetHeight: maxSize,
      );
      final frame = await codec.getNextFrame();
      final data = await frame.image.toByteData(format: ui.ImageByteFormat.png);
      return data!.buffer.asUint8List();
    } catch (e) {
      print('Error creating thumbnail: $e');
      // Fallback to original bytes if resizing fails
      return originalBytes;
    }
  }

