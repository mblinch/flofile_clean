  String _getInningWord(int inning) {
    const inningWords = [
      'first',
      'second',
      'third',
      'fourth',
      'fifth',
      'sixth',
      'seventh',
      'eighth',
      'ninth',
      'tenth',
      'eleventh',
      'twelfth',
      'thirteenth',
      'fourteenth',
      'fifteenth',
      'sixteenth',
      'seventeenth',
      'eighteenth',
      'nineteenth',
      'twentieth',
      'twenty-first',
      'twenty-second',
      'twenty-third',
      'twenty-fourth',
      'twenty-fifth',
      'twenty-sixth',
      'twenty-seventh',
      'twenty-eighth',
      'twenty-ninth',
      'thirtieth'
    ];
    final idx = inning - 1;
    if (idx >= 0 && idx < inningWords.length) {
      return inningWords[idx];
    }
    return '${inning}th';
  }

  String _getInningTextWithWalkOff(int inning) {
    final inningWord = _getInningWord(inning);
    if (inning >= 9) {
      return ' in the $inningWord inning for the walk off win';
    } else {
      return ' in the $inningWord inning';
    }
  }

