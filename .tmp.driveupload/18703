  String _generateObjectName() {
    final meid =
        jobIdController.text.isNotEmpty ? jobIdController.text : 'MEID';
    final descriptionWriter = descriptionWritersController.text.isNotEmpty
        ? descriptionWritersController.text
        : 'MB';
