  // Preload adjacent images for smoother navigation
  void _preloadAdjacentImages() {
    if (imagePaths.isEmpty) return;

    final indicesToPreload = <int>[];
    // Preload more adjacent images for smoother navigation
    for (int i = -2; i <= 2; i++) {
      final index = currentIndex + i;
      if (index >= 0 && index < imagePaths.length && index != currentIndex) {
        indicesToPreload.add(index);
      }
    }

    for (final index in indicesToPreload) {
      final imagePath = imagePaths[index];
      // Preload both full images and thumbnails
      if (!_imageCache.containsKey(imagePath)) {
        _loadImageBytes(imagePath);
      }
      if (!_thumbnailCache.containsKey(imagePath)) {
        _loadThumbnailBytes(imagePath);
      }
    }
  }

  // Clear cache to prevent memory issues
  void _clearImageCache() {
    _imageCache.clear();
    _thumbnailCache.clear();
  }

  // Preload all thumbnails with progress tracking
  Future<void> _preloadAllThumbnails() async {
    if (imagePaths.isEmpty || _isPreloadingThumbnails) return;

    setState(() {
      _isPreloadingThumbnails = true;
      _preloadProgress = 0;
      _totalThumbnailsToPreload = imagePaths.length;
    });

    try {
      // Process in larger batches for better performance
      const int batchSize = 10;
      for (int i = 0; i < imagePaths.length; i += batchSize) {
        final endIndex = (i + batchSize < imagePaths.length)
            ? i + batchSize
            : imagePaths.length;
        final batch = imagePaths.sublist(i, endIndex);

        // Process batch concurrently with higher concurrency
        await Future.wait(
          batch.map((imagePath) async {
            if (!_thumbnailCache.containsKey(imagePath)) {
              await _loadThumbnailBytes(imagePath);
            }
          }),
          eagerError: false, // Don't stop on first error
        );

        setState(() {
          _preloadProgress = endIndex;
        });

        // Reduced delay for faster loading
        await Future.delayed(const Duration(milliseconds: 20));
      }
    } catch (e) {
      print('Error preloading thumbnails: $e');
    } finally {
      setState(() {
        _isPreloadingThumbnails = false;
      });
    }
  }

  // Start preloading when images are loaded
  void _startThumbnailPreload() {
    if (imagePaths.isNotEmpty && !_isPreloadingThumbnails) {
      _preloadAllThumbnails();
