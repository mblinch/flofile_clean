  // Helper function to format player name with jersey number first (for left team)
  Widget _getPlayerDisplayTextWithNumberFirst(Replacement replacement) {
    final jerseyNumber = replacement.jerseyNumber;
    final fullName = replacement.short;

    if (jerseyNumber != null) {
      // Extract name without jersey number
      final nameWithoutNumber =
          fullName.replaceFirst('#$jerseyNumber', '').trim();
      // Add spacing based on jersey number length
      final spacing = jerseyNumber.length == 1 ? '   ' : '  ';
      return RichText(
        text: TextSpan(
          style: const TextStyle(fontSize: 11, color: Colors.black87),
          children: [
            TextSpan(
              text: '#$jerseyNumber$spacing',
              style: const TextStyle(fontWeight: FontWeight.bold),
            ),
            TextSpan(
              text: nameWithoutNumber,
              style: const TextStyle(fontWeight: FontWeight.normal),
            ),
          ],
        ),
      );
    }

    return Text(
      fullName,
      style: const TextStyle(
        fontSize: 11,
        fontWeight: FontWeight.normal,
        color: Colors.black87,
      ),
    );
  }

  // Helper to determine if a specific team should be disabled
  bool _isTeamDisabled(bool isHomeTeam) {
    if (!_shouldDisableOppositeTeam()) return false;

    // Allow opposite team selection in celebration mode
    if (_selectedCelebrationType != null ||
        _isSoloCelebration ||
        celebrateWith.isNotEmpty) {
      return false; // Enable both teams when in any celebration mode
    }

    // If home team has players selected, disable away team
    if (isHomeTeam && selectedPlayers.isNotEmpty) return false;
    if (!isHomeTeam && selectedOpponentPlayers.isNotEmpty) return false;

    // If the opposite team has players selected, disable this team
    if (isHomeTeam && selectedOpponentPlayers.isNotEmpty) return true;
    if (!isHomeTeam && selectedPlayers.isNotEmpty) return true;

    return false;
  }

