  // Helper for fielding options
  Widget _buildFieldingOption(String actionKey, String label) {
    return Padding(
      padding: const EdgeInsets.only(top: 4.0),
      child: FlashingFilterChip(
        label: SizedBox(
          width: _fixedChipWidth,
          child: Text(
            label,
            style: const TextStyle(
              fontSize: 12,
              fontWeight: FontWeight.normal,
