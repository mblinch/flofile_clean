  List<Widget> _buildHomeRunOptions() {
    final hrDisplayLabels = {
      'solo': '1 Run HR',
      'two-run': 'Two Run',
      'three-run': 'Three Run',
      'grand slam': 'GS',
    };
    return [
      if (_selectedHomeRunType == null) ...[
        ...['solo', 'two-run', 'three-run', 'grand slam'].map((type) {
          return Padding(
            padding: const EdgeInsets.only(right: 8.0),
            child: FlashingFilterChip(
              label: SizedBox(
                width: _fixedChipWidth,
                child: Text(
                  hrDisplayLabels[type]!,
                  style: const TextStyle(fontSize: 12),
                  overflow: TextOverflow.ellipsis,
                  textAlign: TextAlign.center,
                ),
              ),
              selected: _selectedHomeRunType == type,
              onSelected: (_) => setState(() {
                _selectedHomeRunType =
                    _selectedHomeRunType == type ? null : type;
                _updateCaption();
              }),
              visualDensity: VisualDensity.compact,
              padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
              labelPadding:
                  const EdgeInsets.symmetric(horizontal: 4, vertical: 1),
              materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
            ),
          );
        }).toList(),
      ] else ...[
        Padding(
          padding: const EdgeInsets.only(right: 8.0),
          child: FlashingFilterChip(
            label: SizedBox(
              width: _fixedChipWidth,
              child: Text(
                hrDisplayLabels[_selectedHomeRunType!]!,
                style: const TextStyle(fontSize: 12),
                overflow: TextOverflow.ellipsis,
                textAlign: TextAlign.center,
              ),
            ),
            selected: true,
            showCheckmark: true,
            onSelected: (_) => setState(() {
              _selectedHomeRunType = null;
              _updateCaption();
            }),
            visualDensity: VisualDensity.compact,
