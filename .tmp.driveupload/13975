  String _getBaseToSlideInto(String hitType) {
    switch (hitType) {
      case 'single':
        return 'first base';
      case 'double':
        return 'second base';
      case 'triple':
        return 'third base';
      case 'home run':
      case 'solo home run':
      case 'two-run home run':
      case 'three-run home run':
