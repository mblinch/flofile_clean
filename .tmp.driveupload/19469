    }
    setState(() {
      selectedPlayers.clear();
      selectedOpponentPlayers.clear(); // Clear opponent players too
      _selectedVerb = null;
      selectedInning = null;
      celebrateWith.clear();
      celebrateAgainst.clear();
    });
    _updateCaption();
  }

