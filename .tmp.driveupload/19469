      // 1. Determine the detailed hit phrase.
      String hitPhrase = '';

      if (_selectedHitType == 'Home Run') {
        String? hrType = _selectedHomeRunType;
        // Only fall back to RBI count if no home run type is explicitly selected
        if (hrType == null && _rbiCount != null) {
          switch (_rbiCount) {
            case 0:
              hrType = 'solo';
              break;
            case 1:
              hrType = 'two-run';
              break;
            case 2:
              hrType = 'three-run';
              break;
            case 3:
              hrType = 'grand slam';
