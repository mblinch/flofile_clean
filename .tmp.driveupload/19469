                                      final soloOnlyVerbs = [
                                        'hit',
                                        'Fielding',
                                        'pitches',
                                        'At Bat',
                                        'Base Running'
                                      ];

                                      if (_selectedVerb != null &&
                                          soloOnlyVerbs
                                              .contains(_selectedVerb) &&
                                          selectedOpponentPlayers.isNotEmpty) {
                                        // For solo verbs, replace the existing player instead of adding
                                        selectedOpponentPlayers.clear();
                                        selectedOpponentPlayers.add(code);
