      vsync: this,
    );
    _personalityTypewriterController = AnimationController(
      duration:
          const Duration(milliseconds: 2000), // 2 seconds for full personality
      vsync: this,
    );

    // Initialize animations
    _captionGlowAnimation = Tween<double>(
      begin: 0.0,
      end: 1.0,
    ).animate(CurvedAnimation(
      parent: _captionGlowController,
      curve: Curves.easeInOut,
    ));

    _captionScaleAnimation = Tween<double>(
      begin: 1.0,
      end: 1.01, // Much more subtle scale
    ).animate(CurvedAnimation(
      parent: _captionScaleController,
      curve: Curves.easeOut, // Simpler curve
    ));

    _captionShakeAnimation = Tween<double>(
      begin: 0.0,
      end: 1.0,
    ).animate(CurvedAnimation(
      parent: _captionShakeController,
      curve: Curves.easeInOut, // Simpler curve
    ));

    _typewriterAnimation = Tween<double>(
      begin: 0.0,
      end: 1.0,
    ).animate(CurvedAnimation(
      parent: _typewriterController,
      curve: Curves.easeInOut,
    ));

    _personalityTypewriterAnimation = Tween<double>(
      begin: 0.0,
      end: 1.0,
    ).animate(CurvedAnimation(
      parent: _personalityTypewriterController,
      curve: Curves.easeInOut,
    ));

    // Listen to typewriter animation to update displayed text
    _typewriterController.addListener(() {
      if (_targetCaption.isNotEmpty && _previousCaption.isNotEmpty) {
        final progress = _typewriterAnimation.value;

        // Find the common prefix by words, not characters
        final oldWords =
            _previousCaption.split(' ').where((w) => w.isNotEmpty).toList();
        final newWords =
            _targetCaption.split(' ').where((w) => w.isNotEmpty).toList();

        int commonWords = 0;
        final minWords = min(oldWords.length, newWords.length);
        for (int i = 0; i < minWords; i++) {
          if (oldWords[i] == newWords[i]) {
            commonWords++;
          } else {
            break;
          }
        }

        // Calculate how many new words to show
        final totalNewWords = newWords.length - commonWords;
        final animatedNewWords = (totalNewWords * progress).round();

        // Build the displayed text
        final displayWords = <String>[];
        displayWords.addAll(newWords.take(commonWords)); // Add common words
        displayWords.addAll(newWords
            .skip(commonWords)
            .take(animatedNewWords)); // Add animated new words

        setState(() {
          _displayedCaption = displayWords.join(' ');
        });

        // When animation completes, update the actual caption controller
        if (progress >= 1.0) {
          captionController.text = _targetCaption;
        }
      } else if (_targetCaption.isNotEmpty) {
        // Fallback for first caption - animate word by word
        final progress = _typewriterAnimation.value;
        final words =
            _targetCaption.split(' ').where((w) => w.isNotEmpty).toList();
        final targetWords = (words.length * progress).round();
        setState(() {
          _displayedCaption = words.take(targetWords).join(' ');
        });

        if (progress >= 1.0) {
          captionController.text = _targetCaption;
        }
      }
    });

    final verbMap = {
      'at bat': 'takes an at bat in his batting stance against the',
      'swings': 'swings against the',
      'single': 'hits a single against the',
      'double': 'hits a double against the',
      'triple': 'hits a triple against the',
      'home run': 'hits a home run against the',
      'pitches': 'delivers a pitch against the',
      'makes a catch': 'makes a catch against the',
      'At Bat':
          'takes an at bat in his batting stance against the', // New entry for the UI button text
      'celebrates defeating': 'celebrates defeating the',
      'Celebrate': 'celebrates', // New single celebrate verb
      'Base Running': 'runs the bases against the',
      'swings': 'swings against the', // At Bat sub-option
      'runs to first base':
          'runs to first base against the', // At Bat sub-option
      // Ensure all soloVerbs and competitionVerbs have entries in codeReplacements if they are to be used like this
      // For instance, 'turns a double play over' isn't in verbMap, so its 'full' form would be itself unless added.
    };
    verbMap.forEach((k, v) {
      codeReplacements[k] = Replacement(v, v, '');
    });
    // Ensure all solo verbs map to a full phrase including "against the"
    for (String verb in soloVerbs) {
      if (!codeReplacements.containsKey(verb)) {
        codeReplacements[verb] = Replacement(
          '$verb against the',
          verb,
          '',
        );
      }
    }
    // Removed: _personShownController.addListener(_updateCaption);
  }

