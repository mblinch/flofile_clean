          // Use "two-run double" style phrasing for walk-offs
          String rbiPart = '';
          if (_rbiCount != null && _rbiCount! > 0) {
            if (_rbiCount == 1) {
              rbiPart = 'RBI';
            } else {
              final rbiWords = {2: 'two', 3: 'three'};
