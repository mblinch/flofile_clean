import 'package:flutter/material.dart';
import 'package:file_picker/file_picker.dart';
import 'dart:io';
import 'package:path/path.dart' as path;

void main() {
  runApp(const CaptionBuilderApp());
}

class CaptionBuilderApp extends StatelessWidget {
  const CaptionBuilderApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Caption Builder',
      theme: ThemeData(
        primarySwatch: Colors.blue,
        useMaterial3: true,
      ),
      home: const CaptionBuilderScreen(),
    );
  }
}

class CaptionBuilderScreen extends StatefulWidget {
  const CaptionBuilderScreen({super.key});

  @override
  State<CaptionBuilderScreen> createState() => _CaptionBuilderScreenState();
}

class _CaptionBuilderScreenState extends State<CaptionBuilderScreen> {
  List<String> imagePaths = [];
  int currentIndex = 0;
  final TextEditingController _captionController = TextEditingController();
  final ScrollController _filmstripController = ScrollController();

  @override
  void dispose() {
    _captionController.dispose();
    _filmstripController.dispose();
    super.dispose();
  }

  Future<void> _pickImages() async {
    try {
      FilePickerResult? result = await FilePicker.platform.pickFiles(
        type: FileType.image,
        allowMultiple: true,
      );

      if (result != null) {
        setState(() {
          imagePaths = result.paths
              .where((path) => path != null)
              .cast<String>()
              .toList();
          currentIndex = 0;
          _captionController.clear();
        });
      }
    } catch (e) {
      print('Error picking images: $e');
    }
  }

  void _nextImage() {
    if (imagePaths.isNotEmpty && currentIndex < imagePaths.length - 1) {
      setState(() {
        currentIndex++;
        _captionController.clear();
      });
      _scrollToCurrentImage();
    }
  }

  void _previousImage() {
    if (imagePaths.isNotEmpty && currentIndex > 0) {
      setState(() {
        currentIndex--;
        _captionController.clear();
      });
      _scrollToCurrentImage();
    }
  }

  void _selectImage(int index) {
    setState(() {
      currentIndex = index;
      _captionController.clear();
    });
    _scrollToCurrentImage();
  }

  void _scrollToCurrentImage() {
    if (imagePaths.isNotEmpty) {
      final itemWidth = 150.0; // Approximate thumbnail width
      final targetOffset = currentIndex * itemWidth;
      _filmstripController.animateTo(
        targetOffset,
        duration: const Duration(milliseconds: 300),
        curve: Curves.easeInOut,
      );
    }
  }

  void _saveCaption() {
    if (imagePaths.isEmpty || _captionController.text.trim().isEmpty) return;

    final imagePath = imagePaths[currentIndex];
    final caption = _captionController.text.trim();
    final imageName = path.basename(imagePath);
    final captionPath = path.join(path.dirname(imagePath),
        '${path.basenameWithoutExtension(imageName)}_caption.txt');

    try {
      File(captionPath).writeAsStringSync(caption);
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Caption saved: ${path.basename(captionPath)}')),
      );
    } catch (e) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Error saving caption: $e')),
      );
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Caption Builder'),
        actions: [
          IconButton(
            icon: const Icon(Icons.folder_open),
            onPressed: _pickImages,
            tooltip: 'Select Images',
          ),
        ],
      ),
      body: Column(
        children: [
          // Main image display
          Expanded(
            flex: 3,
            child: Container(
              width: double.infinity,
              margin: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                border: Border.all(color: Colors.grey.shade300),
                borderRadius: BorderRadius.circular(8),
              ),
              child: imagePaths.isEmpty
                  ? const Center(
                      child: Text('No images selected'),
                    )
                  : ClipRRect(
                      borderRadius: BorderRadius.circular(8),
                      child: Image.file(
                        File(imagePaths[currentIndex]),
                        fit: BoxFit.contain,
                        errorBuilder: (context, error, stackTrace) {
                          return Container(
                            color: Colors.grey.shade200,
                            child: const Center(
                              child: Icon(Icons.error, color: Colors.grey),
                            ),
                          );
                        },
                      ),
                    ),
            ),
          ),

          // Caption input
          Container(
            padding: const EdgeInsets.all(16),
            child: Column(
              children: [
                TextField(
                  controller: _captionController,
                  maxLines: 3,
                  decoration: const InputDecoration(
                    labelText: 'Caption',
                    border: OutlineInputBorder(),
                  ),
                ),
                const SizedBox(height: 16),
                Row(
                  mainAxisAlignment: MainAxisAlignment.spaceEvenly,
                  children: [
                    ElevatedButton.icon(
                      onPressed: _previousImage,
                      icon: const Icon(Icons.arrow_back),
                      label: const Text('Previous'),
                    ),
                    ElevatedButton.icon(
                      onPressed: _saveCaption,
                      icon: const Icon(Icons.save),
                      label: const Text('Save Caption'),
                    ),
                    ElevatedButton.icon(
                      onPressed: _nextImage,
                      icon: const Icon(Icons.arrow_forward),
                      label: const Text('Next'),
                    ),
                  ],
                ),
              ],
            ),
          ),

          // Thumbnail filmstrip
          if (imagePaths.isNotEmpty)
            Container(
              height: 120,
              padding: const EdgeInsets.symmetric(vertical: 8),
              child: ListView.builder(
                controller: _filmstripController,
                scrollDirection: Axis.horizontal,
                itemCount: imagePaths.length,
                itemBuilder: (context, index) {
                  final isSelected = index == currentIndex;
                  return GestureDetector(
                    onTap: () => _selectImage(index),
                    child: Container(
                      width: 100,
                      margin: const EdgeInsets.symmetric(horizontal: 4),
                      decoration: BoxDecoration(
                        border: Border.all(
                          color:
                              isSelected ? Colors.blue : Colors.grey.shade300,
                          width: isSelected ? 3 : 1,
                        ),
                        borderRadius: BorderRadius.circular(4),
                      ),
                      child: ClipRRect(
                        borderRadius: BorderRadius.circular(4),
                        child: Image.file(
                          File(imagePaths[index]),
                          fit: BoxFit.cover,
                          errorBuilder: (context, error, stackTrace) {
                            return Container(
                              color: Colors.grey.shade200,
                              child: const Center(
                                child: Icon(Icons.error,
                                    color: Colors.grey, size: 16),
                              ),
                            );
                          },
                        ),
                      ),
                    ),
                  );
                },
              ),
            ),
        ],
      ),
    );
  }
}
