      'Ú': 'U',
      'Û': 'U',
      'Ü': 'U',
      'Ý': 'Y',
      'Ñ': 'N',
      'Ç': 'C',
    };

    String result = text;
    diacriticMap.forEach((accented, plain) {
      result = result.replaceAll(accented, plain);
    });

    return result;
