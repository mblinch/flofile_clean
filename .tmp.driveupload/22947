  // Simple spell checking function
  void _checkSpelling(String text) {
    if (_isSpellChecking) return;

    setState(() {
      _isSpellChecking = true;
    });

    // Simple word extraction and basic spell checking
    final words = text
        .split(RegExp(r'\s+'))
        .where((word) =>
                word.isNotEmpty &&
                word.length > 2 &&
                !RegExp(r'^[A-Z][a-z]+$').hasMatch(word) // Skip proper nouns
            )
        .toList();

    // For now, just mark words that are very short or contain numbers as potentially misspelled
    // This is a placeholder - in a real implementation you'd use a proper dictionary
    final misspelled = words
        .where((word) =>
            word.length < 3 ||
            RegExp(r'\d').hasMatch(word) ||
            word.contains('_') ||
            word.contains('-'))
        .toList();

    setState(() {
      _misspelledWords = misspelled;
      _isSpellChecking = false;
    });
  }

  // Build RichText with spell check highlighting
  TextSpan _buildSpellCheckedText(String text) {
    if (_misspelledWords.isEmpty) {
      return TextSpan(
        text: text,
        style: const TextStyle(
          fontSize: 14,
          color: Colors.transparent,
        ),
      );
    }

    final spans = <TextSpan>[];
    final words = text.split(RegExp(r'(\s+)'));

    for (final word in words) {
      if (_misspelledWords.contains(word.trim())) {
        spans.add(TextSpan(
          text: word,
          style: const TextStyle(
            fontSize: 14,
            color: Colors.transparent,
            decoration: TextDecoration.underline,
            decorationColor: Colors.red,
            decorationThickness: 2,
          ),
        ));
      } else {
        spans.add(TextSpan(
          text: word,
          style: const TextStyle(
            fontSize: 14,
            color: Colors.transparent,
          ),
        ));
      }
    }

    return TextSpan(children: spans);
  }

