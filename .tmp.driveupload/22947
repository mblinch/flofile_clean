  // Function to generate Object Name with FTP pattern
  String _generateObjectName() {
    final meid =
        jobIdController.text.isNotEmpty ? jobIdController.text : 'MEID';
    final descriptionWriter = descriptionWritersController.text.isNotEmpty
        ? descriptionWritersController.text
        : 'MB';
    final picNumber =
        _ftpPictureNumber.toString().padLeft(3, '0'); // 001, 002, etc.
    final visitingTeam = selectedAwayTeam ?? 'VisitingTeam';
    final homeTeam = selectedHomeTeam ?? 'HomeTeam';

    return '776271572_MB_00_VJAYS ${meid}_${descriptionWriter}_${picNumber}_${visitingTeam}vs${homeTeam}';
  }

