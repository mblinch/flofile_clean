class Replacement {
  final String full;
  final String short;
  final String firstName;
  final String? jerseyNumber;
  Replacement(this.full, this.short, this.firstName, [this.jerseyNumber]);

  // Consider if this `fullTeam` logic is robust enough.
  // It relies on "of the" being in the `full` string.
  String get fullTeam {
    if (full.contains('of the')) {
      final parts = full.split('of the');
      return parts.length > 1 ? parts[1].trim() : '';
    }
    return '';
  }
}

