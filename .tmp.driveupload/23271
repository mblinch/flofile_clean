import 'dart:convert';
import 'package:http/http.dart' as http;

void main() async {
  print('Testing API-Sports structure...');

  try {
    // First, let's check what leagues are available
    print('\n=== Checking Leagues ===');
    final leaguesUrl = Uri.https('v1.baseball.api-sports.io', '/leagues');
    final leaguesResp = await http.get(
      leaguesUrl,
      headers: {'x-apisports-key': 'ac9bc3548464f0f74ab4e1e76b061599'},
    );

    print('Leagues Status: ${leaguesResp.statusCode}');
    if (leaguesResp.statusCode == 200) {
      final leaguesData = jsonDecode(leaguesResp.body);
      print('Leagues response keys: ${leaguesData.keys.toList()}');
      if (leaguesData.containsKey('response')) {
        final leagues = leaguesData['response'] as List<dynamic>;
        print('Leagues found: ${leagues.length}');
        for (final league in leagues.take(5)) {
          print('League: $league');
        }
      }
    }

    // Now check teams with different parameters
    print('\n=== Checking Teams ===');
    final teamsUrl = Uri.https('v1.baseball.api-sports.io', '/teams');
    final teamsResp = await http.get(
      teamsUrl,
      headers: {'x-apisports-key': 'ac9bc3548464f0f74ab4e1e76b061599'},
    );

    print('Teams Status: ${teamsResp.statusCode}');
    if (teamsResp.statusCode == 200) {
      final teamsData = jsonDecode(teamsResp.body);
      print('Teams response keys: ${teamsData.keys.toList()}');

      // Check each key
      for (final key in teamsData.keys) {
        print('\nKey: $key');
        print('Type: ${teamsData[key].runtimeType}');
        if (teamsData[key] is Map) {
          print('Map keys: ${(teamsData[key] as Map).keys.toList()}');
        } else if (teamsData[key] is List) {
          print('List length: ${(teamsData[key] as List).length}');
          if ((teamsData[key] as List).isNotEmpty) {
            print('First item: ${(teamsData[key] as List).first}');
          }
        }
      }
    }
  } catch (e) {
    print('Error: $e');
  }
}
