import 'package:flutter/material.dart';

void main() {
  runApp(const CaptionWriterApp());
}

class CaptionWriterApp extends StatelessWidget {
  const CaptionWriterApp({super.key});

  @override
  Widget build(BuildContext context) {
    return const MaterialApp(
      home: CaptionHomePage(),
    );
  }
}

class CaptionHomePage extends StatefulWidget {
  const CaptionHomePage({super.key});

  @override
  State<CaptionHomePage> createState() => _CaptionHomePageState();
}

class _CaptionHomePageState extends State<CaptionHomePage> {
  String? selectedJay;
  String? selectedDback;
  String? selectedAction;
  String? selectedInning;
  String caption = '';

  final List<String> jays = [
    'Vladimir Guerrero Jr. #27',
    'Bo Bichette #11',
    'George Springer #4',
  ];

  final List<String> dbacks = [
    'Lourdes Gurriel Jr. #12',
    'Ketel Marte #4',
    'Corbin Carroll #7',
  ];

  final List<String> actions = [
    'swings',
    'hits a single',
    'hits a double',
    'hits a triple',
    'hits a home run',
    'stands in his at bat stance',
  ];

  final List<String> innings = [
    'first inning',
    'second inning',
    'third inning',
    'fourth inning',
    'fifth inning',
    'sixth inning',
    'seventh inning',
    'eighth inning',
    'ninth inning',
  ];

  void updateCaption() {
    if (selectedJay != null && selectedDback != null && selectedAction != null && selectedInning != null) {
      setState(() {
        caption =
            'TORONTO, ON - JUNE 20: $selectedJay $selectedAction against $selectedDback in the $selectedInning at Rogers Centre on June 20, 2025 in Toronto, Ontario, Canada. (Photo by Mark Blinch/Getty Images)';
      });
    }
  }

  Widget dropdown(String label, List<String> items, String? value, Function(String?) onChanged) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 8),
      child: DropdownButtonFormField<String>(
        decoration: InputDecoration(labelText: label, border: const OutlineInputBorder()),
        value: value,
        items: items.map((item) => DropdownMenuItem(value: item, child: Text(item))).toList(),
        onChanged: (newValue) {
          onChanged(newValue);
          updateCaption();
        },
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('Caption Builder')),
      body: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          children: [
            dropdown('Blue Jays Player', jays, selectedJay, (val) => selectedJay = val),
            dropdown('Diamondbacks Player', dbacks, selectedDback, (val) => selectedDback = val),
            dropdown('Action', actions, selectedAction, (val) => selectedAction = val),
            dropdown('Inning', innings, selectedInning, (val) => selectedInning = val),
            const SizedBox(height: 24),
            const Text('Generated Caption:', style: TextStyle(fontWeight: FontWeight.bold)),
            const SizedBox(height: 8),
            SelectableText(caption),
          ],
        ),
      ),
    );
  }
}
import 'package:flutter/material.dart';
import 'dart:io';
import 'package:file_picker/file_picker.dart';

void main() {
  runApp(CaptionWriterApp());
}

class CaptionWriterApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Caption Writer',
      home: CaptionHomePage(),
      debugShowCheckedModeBanner: false,
    );
  }
}

class CaptionHomePage extends StatefulWidget {
  @override
  _CaptionHomePageState createState() => _CaptionHomePageState();
}

class _CaptionHomePageState extends State<CaptionHomePage> {
  final TextEditingController _codeController = TextEditingController();
  String _selectedSport = 'MLB';
  String _captionOutput = '';
  Map<String, String> _codeMap = {};
  String? _selectedVerb;
  final List<String> _verbs = [
  ];
  String? _selectedInning;
  final Map<String, String> _innings = {
    'd1i': 'first inning',
    'd2i': 'second inning',
    'd3i': 'third inning',
    'd4i': 'fourth inning',
    'd5i': 'fifth inning',
    'd6i': 'sixth inning',
    'd7i': 'seventh inning',
    'd8i': 'eighth inning',
    'd9i': 'ninth inning',
    'd10i': 'tenth inning',
    'd11i': 'eleventh inning',
    'd12i': 'twelfth inning',
    'd13i': 'thirteenth inning',
    'd14i': 'fourteenth inning',
    'd15i': 'fifteenth inning',
    'd16i': 'sixteenth inning',
    'd17i': 'seventeenth inning',
    'd18i': 'eighteenth inning',
    'd19i': 'nineteenth inning',
    'd20i': 'twentieth inning',
    'd21i': 'twenty-first inning',
    'd22i': 'twenty-second inning',
  };
    'swings',
    'hits a single',
    'hits a double',
    'hits a triple',
    'hits a home run',
    'stands in his at bat stance',
  ];
  String? _selectedHomeCode;
  String? _selectedAwayCode;
  List<String> _homeCodes = [];
  List<String> _awayCodes = [];

  Future<void> _loadCodeFile() async {
    FilePickerResult? result = await FilePicker.platform.pickFiles(
      type: FileType.custom,
      allowedExtensions: ['txt'],
    );

    if (result != null) {
      final file = File(result.files.single.path!);
      final lines = await file.readAsLines();

      final newMap = <String, String>{};
      final home = <String>[];
      final away = <String>[];

      for (var line in lines) {
        if (line.trim().isEmpty || !line.contains('\t')) continue;
        final parts = line.split('\t');
        if (parts.length >= 2) {
          final code = parts[0].trim();
          final caption = parts[1].trim();
          newMap[code] = caption;
          if (RegExp(r'^h\d{1,2}[a-z]?$').hasMatch(code)) {
            home.add(code);
          } else if (RegExp(r'^v\d{1,2}[a-z]?$').hasMatch(code)) {
            away.add(code);
          }
        }
      }

      setState(() {
        _codeMap = newMap;
        _homeCodes = home;
        _awayCodes = away;
        _captionOutput = '✅ Code file loaded. Select players or enter codes.';
      });
    }
  }

  void _updateCaption() {
    final manualInput = _codeController.text.trim();
    final List<String> allCodes = [];

    if (_selectedHomeCode != null) allCodes.add(_selectedHomeCode!);
    if (_selectedAwayCode != null) allCodes.add(_selectedAwayCode!);
    if (manualInput.isNotEmpty) {
      allCodes.addAll(manualInput.split(RegExp(r'\s+')));
    }

    final List<String> phrases = [];
    final List<String> players = [];

    for (final code in allCodes) {
      final result = _codeMap[code];
      if (result != null) {
        phrases.add(result);
        final hashIndex = result.indexOf('#');
        if (hashIndex > 0) {
          final name = result.substring(0, hashIndex).trim();
          if (!players.contains(name)) {
            players.add(name);
          }
        }
      }
    }

    if (phrases.isEmpty) {
      setState(() {
        _captionOutput = '❌ None of the codes were found.';
      });
      return;
    }

    final opponent = _codeMap['v'] ?? '[Opponent]';
    final stadium = _codeMap['stad'] ?? '[Stadium]';

    final now = DateTime.now();
    final month = [
      '', 'January', 'February', 'March', 'April', 'May', 'June',
      'July', 'August', 'September', 'October', 'November', 'December'
    ][now.month];
    final formattedDate = '\$month \${now.day}, \${now.year}';
    final dateline = 'TORONTO, ON - \${month.toUpperCase()} \${now.day}:';

    final action = _selectedVerb != null && players.isNotEmpty
        ? '\${players.first} \$_selectedVerb against \$opponent'
        : phrases.join(" ");
    final inningPhrase = _selectedInning != null ? ' during the ' + _innings[_selectedInning!]! : '';
    final fullCaption = '\$dateline \$action\$inningPhrase in their MLB game at \$stadium on \$formattedDate in Toronto, Ontario, Canada. (Photo by Mark Blinch/Getty Images)';
    final playerList = players.join(';');

    setState(() {
      _captionOutput = '\$fullCaption\n\nPlayers: \$playerList';
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text('Caption Writer')),
      body: Padding(
        padding: const EdgeInsets.all(20.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            ElevatedButton.icon(
              onPressed: _loadCodeFile,
              icon: Icon(Icons.folder_open),
              label: Text('Load Code File'),
            ),
            SizedBox(height: 20),
            Row(
              children: [
                Expanded(
                  child: DropdownButton<String>(
                    isExpanded: true,
                    value: _selectedHomeCode,
                    hint: Text('Select Blue Jays Player'),
                    items: _homeCodes.map((code) {
                      return DropdownMenuItem<String>(
                        value: code,
                        child: Text(_codeMap[code] ?? code),
                      );
                    }).toList(),
                    onChanged: (value) {
                      setState(() {
                        _selectedHomeCode = value;
                      });
                      _updateCaption();
                    },
                  ),
                ),
                SizedBox(width: 16),
                Expanded(
                  child: DropdownButton<String>(
                    isExpanded: true,
                    value: _selectedAwayCode,
                    hint: Text('Select Diamondbacks Player'),
                    items: _awayCodes.map((code) {
                      return DropdownMenuItem<String>(
                        value: code,
                        child: Text(_codeMap[code] ?? code),
                      );
                    }).toList(),
                    onChanged: (value) {
                      setState(() {
                        _selectedAwayCode = value;
                      });
                      _updateCaption();
                    },
                  ),
                ),
              ],
            ),
            SizedBox(height: 20),
            TextField(
              controller: _codeController,
              decoration: InputDecoration(labelText: 'Enter extra code(s), e.g. d1i'),
              onChanged: (_) => _updateCaption(),
            ),
            SizedBox(height: 20),
            
            SizedBox(height: 20),
            DropdownButton<String>(
              isExpanded: true,
              value: _selectedVerb,
              hint: Text('Select Action'),
              items: _verbs.map((verb) {
                return DropdownMenuItem<String>(
                  value: verb,
                  child: Text(verb),
                );
              }).toList(),
              onChanged: (value) {
                setState(() {
                  _selectedVerb = value;
                });
                _updateCaption();
              },
            ),
            SizedBox(height: 20),
            DropdownButton<String>(
              isExpanded: true,
              value: _selectedInning,
              hint: Text('Select Inning'),
              items: _innings.entries.map((entry) {
                return DropdownMenuItem<String>(
                  value: entry.key,
                  child: Text(entry.value),
                );
              }).toList(),
              onChanged: (value) {
                setState(() {
                  _selectedInning = value;
                });
                _updateCaption();
              },
            ),
            SizedBox(height: 20),
              hint: Text('Select Action'),
              items: _verbs.map((verb) {
                return DropdownMenuItem<String>(
                  value: verb,
                  child: Text(verb),
                );
              }).toList(),
              onChanged: (value) {
                setState(() {
                  _selectedVerb = value;
                });
                _updateCaption();
              },
            ),
            SizedBox(height: 20),
            SelectableText(

              _captionOutput,
              style: TextStyle(fontSize: 16),
            ),
          ],
        ),
      ),
    );
  }
}
