class MyApp extends StatelessWidget {
  const MyApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Quick Cap',
      theme: ThemeData(
        colorScheme: ColorScheme.fromSeed(
          seedColor: const Color(0xFF2E3A59), // Cool Gray
          brightness: Brightness.light,
        ),
        useMaterial3: true,
        fontFamily: 'RobotoCondensed',
        textTheme: ThemeData.light().textTheme.copyWith(
          bodyMedium: const TextStyle(fontSize: 11),
          bodySmall: const TextStyle(fontSize: 10),
          titleMedium: const TextStyle(fontSize: 12, fontWeight: FontWeight.bold),
        ),
        elevatedButtonTheme: ElevatedButtonThemeData(
          style: ElevatedButton.styleFrom(
            backgroundColor: const Color(0xFF2E3A59), // Cool Gray
            foregroundColor: Colors.white,
            padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 12),
            textStyle: const TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
          ),
        ),
        textButtonTheme: TextButtonThemeData(
          style: TextButton.styleFrom(
            foregroundColor: const Color(0xFF00A8E8), // Sky Blue Accent
          ),
        ),
        inputDecorationTheme: const InputDecorationTheme(
          border: OutlineInputBorder(),
        ),
      ),
      home: const CaptionBuilder(),
    );
  }

}

class Replacement {
  final String full;
  final String short;
  final String firstName;
  Replacement(this.full, this.short, this.firstName);

  // Consider if this `fullTeam` logic is robust enough.
  // It relies on "of the" being in the `full` string.
  String get fullTeam {
    if (full.contains('of the')) {
      final parts = full.split('of the');
      return parts.length > 1 ? parts[1].trim() : '';
    }
    return '';
  }
}

/// Intent to toggle Home/Away player list via keyboard
class ToggleHomeAwayIntent extends Intent {}

class CaptionBuilder extends StatefulWidget {
  const CaptionBuilder({super.key});

  @override
  _CaptionBuilderState createState() => _CaptionBuilderState();
}

class FlashingFilterChip extends StatefulWidget {
  final Widget label;
  final bool selected;
  final ValueChanged<bool>? onSelected;
  final VisualDensity? visualDensity;
  final EdgeInsetsGeometry? padding;
  final EdgeInsetsGeometry? labelPadding;
  final MaterialTapTargetSize? materialTapTargetSize;
  final bool showCheckmark;

  const FlashingFilterChip({
    Key? key,
    required this.label,
    required this.selected,
    this.onSelected,
    this.visualDensity,
    this.padding,
    this.labelPadding,
    this.materialTapTargetSize,
    this.showCheckmark = true,
  }) : super(key: key);

  @override
  _FlashingFilterChipState createState() => _FlashingFilterChipState();
}

class _FlashingFilterChipState extends State<FlashingFilterChip>
    with SingleTickerProviderStateMixin {
  late AnimationController _controller;
  Animation<Color?>? _animation;

  @override
  void initState() {
    super.initState();
    _controller = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 400), // Made it a bit faster
    );
  }

  @override
  void didUpdateWidget(FlashingFilterChip oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (widget.selected && !oldWidget.selected && widget.onSelected != null) {
      // Just got selected
      final chipTheme = ChipTheme.of(context);
      const flashColor = Color(0xFFEEEEEE); // A very light grey for flash (grey.shade200)
      const selectedColor = Color(0xFFE0E0E0); // A light grey for selected state (grey.shade300)
      final unselectedColor = chipTheme.backgroundColor ??
          Theme.of(context).colorScheme.surfaceContainerHighest;

      _animation = TweenSequence<Color?>([
        TweenSequenceItem(tween: ColorTween(begin: unselectedColor, end: flashColor), weight: 30),
        TweenSequenceItem(tween: ColorTween(begin: flashColor, end: unselectedColor), weight: 30),
        TweenSequenceItem(tween: ColorTween(begin: unselectedColor, end: selectedColor), weight: 40),
      ]).animate(_controller);

      _controller.forward(from: 0.0);
    }
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final chipTheme = ChipTheme.of(context);
    const selectedColor = Color(0xFFE0E0E0); // A light grey for selected state (grey.shade300)
    final backgroundColor = chipTheme.backgroundColor;

    return AnimatedBuilder(
      animation: _controller,
      builder: (context, child) {
        Color? currentBgColor;
        if (widget.selected) {
          if (_controller.isAnimating && _animation != null) {
            currentBgColor = _animation!.value;
          } else {
            currentBgColor = selectedColor;
          }
        } else {
          currentBgColor = backgroundColor;
        }

        return FilterChip(
          label: widget.label,
          selected: widget.selected,
          onSelected: widget.onSelected,
          showCheckmark: widget.showCheckmark,
          backgroundColor: currentBgColor,
          selectedColor: currentBgColor, // Override to control color during animation
          visualDensity: widget.visualDensity,
          padding: widget.padding,
          labelPadding: widget.labelPadding,
          materialTapTargetSize: widget.materialTapTargetSize,
        );
      },
    );
  }
}

class _CaptionBuilderState extends State<CaptionBuilder> {
  bool _showExtraInnings = false;
  String? _customInningText;
  bool _showHomeFirst = true;
  bool _showHitTypes = false;
  bool _walkOff = false;

  // Hit selection state
  String? _selectedHitType; // 'single', 'double', 'triple', 'home run'
  String? _selectedHomeRunType; // 'solo', 'two-run', 'three-run', 'grand slam'
  bool? _isRBI;
  int? _rbiCount;
  int? _selectedRbiInning;
  int? _onBaseCount;
  bool? _isBatterRunning;

  // Preserve per-hit-type selections
  Widget _buildArrow() {
    return const SizedBox(
      height: 32.0, // A common touch target height, aligns well with compact chips.
      child: Center(
        child: Text('→', style: TextStyle(fontSize: 12)),
      ),
    );
  }

  final Map<String, int?> _rbiCountByHit = {};
  final Map<String, String?> _homeRunTypeByHit = {};
  final Map<String, int?> _inningByHit = {};
  final Map<String, bool?> _batterRunningByHit = {};

  // --- Patch: State fields for hit row/chip keys and indent
  final GlobalKey _hitRowKey = GlobalKey();
  final Map<String, GlobalKey> _hitChipKeys = {
    'single': GlobalKey(),
    'double': GlobalKey(),
    'triple': GlobalKey(),
    'home run': GlobalKey(),
  };
  double _batterIndent = 0.0;
  final GlobalKey _batterRunningKey = GlobalKey();
  final double _fixedChipWidth = 70.0;
  
  // --- Portrait chip state
  final GlobalKey _portraitRowKey = GlobalKey();
  bool _showLooksOn = false;
  bool _isLooksOn = false;
  double _portraitIndent = 0.0;

  // Keys and indent for inning row
  final GlobalKey _inningRowKey = GlobalKey();
  final Map<int, GlobalKey> _inningChipKeys = {
    for (var i = 1; i <= 22; i++) i: GlobalKey(),
  };
  double _inningIndent = 0.0;

  // Patch: Fielding row and chip keys and indent
  final GlobalKey _fieldingRowKey = GlobalKey();
  final Map<String, GlobalKey> _fieldingChipKeys = {
    'makes a catch': GlobalKey(),
    'fields a ground ball': GlobalKey(),
    'throws a ball': GlobalKey(),
    'stands in fielding position': GlobalKey(),
  };
  double _fieldingIndent = 0.0;

  /// Reusable inline inning selector
  Widget buildInlineInningSelector({
    required int? selectedInning,
    required bool showExtraInnings,
    required ValueChanged<int?> onInningSelected,
    required VoidCallback onExtraToggle,
    bool allowCustom = false,
    VoidCallback? onBack,
    String? currentCustomInningText,
    bool showWalkOffOption = false,
  }) {
    final bool isSelectionComplete = selectedInning != null || (currentCustomInningText != null && currentCustomInningText.isNotEmpty);

    if (isSelectionComplete) {
      String displayInningText;
      if (currentCustomInningText != null && currentCustomInningText.isNotEmpty) {
        displayInningText = currentCustomInningText;
      } else {
        if (selectedInning == 1) {
          displayInningText = '1st';
        } else if (selectedInning == 2) {
          displayInningText = '2nd';
        } else if (selectedInning == 3) {
          displayInningText = '3rd';
        } else {
          displayInningText = '${selectedInning}th';
        }
      }
      final selectedInningRow = SingleChildScrollView(
        key: _inningRowKey,
        scrollDirection: Axis.horizontal,
        child: SizedBox(
          height: 32.0,
          child: Builder(
            builder: (ctx) {
              WidgetsBinding.instance.addPostFrameCallback((_) {
                final rowContext = _inningRowKey.currentContext;
                final chipContext = _inningChipKeys[selectedInning!]?.currentContext;
                if (rowContext == null || chipContext == null) return;
                final rowRender = rowContext.findRenderObject();
                final chipRender = chipContext.findRenderObject();
                if (rowRender is! RenderBox || chipRender is! RenderBox) return;
                final rowPos = rowRender.localToGlobal(Offset.zero);
                final chipPos = (chipRender).localToGlobal(Offset.zero);
                setState(() {
                  _inningIndent = chipPos.dx - rowPos.dx;
                });
              });
              return Row(
                mainAxisSize: MainAxisSize.min,
                children: [
                  Chip(
                    key: _inningChipKeys[selectedInning!],
                    label: Text(displayInningText, style: const TextStyle(fontSize: 11, fontWeight: FontWeight.bold)),
                    deleteIcon: const Icon(Icons.cancel, size: 18),
                    onDeleted: () => onInningSelected(null),
                    backgroundColor: Colors.green.shade100,
                    padding: const EdgeInsets.symmetric(horizontal: 4),
                    materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                    labelPadding: const EdgeInsets.only(left: 8),
                    visualDensity: VisualDensity.compact,
                  ),
                  const SizedBox(width: 8),
                  ElevatedButton.icon(
                    onPressed: () {
                      print("FTP action triggered!");
                    },
                    icon: const Icon(Icons.upload, size: 16),
                    label: const Text('FTP'),
                    style: ElevatedButton.styleFrom(
                      backgroundColor: Colors.green.shade600,
                      foregroundColor: Colors.white,
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(8)),
                      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                      textStyle: const TextStyle(fontSize: 12, fontWeight: FontWeight.bold),
                    ),
                  ),
                ],
              );
            },
          ),
        ),
      );
      return Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          selectedInningRow,
          if (showWalkOffOption && selectedInning == 9)
            Padding(
              padding: EdgeInsets.only(top: 4.0, left: _inningIndent),
              child: FlashingFilterChip(
                label: SizedBox(
                  width: _fixedChipWidth,
                  child: const Center(child: Text('Walk-off win', style: TextStyle(fontSize: 12))),
                ),
                selected: _walkOff,
                onSelected: (isSelected) {
                  setState(() {
                    _walkOff = isSelected;
                    _updateCaption();
                  });
                },
                visualDensity: VisualDensity.compact,
                padding: EdgeInsets.zero,
                labelPadding: const EdgeInsets.symmetric(horizontal: 8),
                materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
              ),
            ),
        ],
      );
    } else {
      // Patch: Wrap the inning row in SingleChildScrollView with key and chip keys
      if (!showExtraInnings) {
        return SingleChildScrollView(
          key: _inningRowKey,
          scrollDirection: Axis.horizontal,
          child: Row(
            mainAxisSize: MainAxisSize.min,
            children: [
              ...List.generate(9, (i) => i + 1).map((inning) =>
                FlashingFilterChip(
                  key: _inningChipKeys[inning],
                  label: Text(inning == 1 ? '1st' : inning == 2 ? '2nd' : inning == 3 ? '3rd' : '${inning}th', style: const TextStyle(fontSize: 11)),
                  selected: selectedInning == inning,
                  onSelected: (selected) {
                    onInningSelected(inning);
                    WidgetsBinding.instance.addPostFrameCallback((_) {
                      final rowContext = _inningRowKey.currentContext;
                      final chipContext = _inningChipKeys[inning]?.currentContext;
                      if (rowContext == null || chipContext == null) return;
                      final rowRender = rowContext.findRenderObject();
                      final chipRender = chipContext.findRenderObject();
                      if (rowRender is! RenderBox || chipRender is! RenderBox) return;
                      final rowPos = rowRender.localToGlobal(Offset.zero);
                      final chipPos = chipRender.localToGlobal(Offset.zero);
                      setState(() {
                        _inningIndent = chipPos.dx - rowPos.dx;
                      });
                    });
                  },
                  visualDensity: VisualDensity.compact,
                  padding: EdgeInsets.zero,
                  labelPadding: const EdgeInsets.symmetric(horizontal: 8),
                  materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                )
              ),
              // ... leave Extra button logic unchanged
              TextButton(
                onPressed: onExtraToggle,
                style: TextButton.styleFrom(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2),
                  minimumSize: Size.zero,
                  tapTargetSize: MaterialTapTargetSize.shrinkWrap,
                ),
                child: const Text('Extra', style: TextStyle(fontSize: 11, fontWeight: FontWeight.bold)),
              ),
            ],
          ),
        );
      } else {
        final children = <Widget>[
          ...List.generate(9, (i) => i + 10).map((inning) =>
            FlashingFilterChip(
              label: Text('${inning}th', style: const TextStyle(fontSize: 11)),
              selected: selectedInning == inning,
              onSelected: (selected) => onInningSelected(inning),
              visualDensity: VisualDensity.compact,
              padding: EdgeInsets.zero,
              labelPadding: const EdgeInsets.symmetric(horizontal: 8),
              materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
            )
          ),
          if (allowCustom)
            TextButton(onPressed: () => onInningSelected(-1), style: TextButton.styleFrom(padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2), minimumSize: Size.zero, tapTargetSize: MaterialTapTargetSize.shrinkWrap), child: const Text('Custom', style: TextStyle(fontSize: 11, fontWeight: FontWeight.bold))),
          if (onBack != null)
            TextButton(onPressed: onBack, style: TextButton.styleFrom(padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 2), minimumSize: Size.zero, tapTargetSize: MaterialTapTargetSize.shrinkWrap), child: const Text('Back', style: TextStyle(fontSize: 11, fontWeight: FontWeight.bold))),
        ];
        return Row(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.center,
            children: children.expand((w) => [w, const SizedBox(width: 2.0)]).toList()..removeLast(),
          );
      }
    }
  }

  /// Returns the inning phrase, e.g. "during the seventh inning"
  String get inningPhrase {
    if (selectedInning != null) {
      return 'during the $selectedInning inning';
    }
    return '';
  }
  /// List of solo and competition verb phrases for logic/UI.
  // Helper to build a single list of all verbs with category headers.
  List<Widget> _buildAllVerbsList() {
    final List<Widget> widgets = [];
    final allVerbs = verbCategories.values.expand((list) => list);
    for (final verb in allVerbs) {
      // Only display the verb if no verb is selected, or if this is the selected verb
      if (_selectedVerb == null || _selectedVerb == verb) {
        if (verb == 'hit') {
          widgets.add(
            Padding(
              padding: const EdgeInsets.only(bottom: 2.0, top: 4.0),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  // PATCH: Add key to SingleChildScrollView for hit-type row
                  SingleChildScrollView(
                    key: _hitRowKey,
                    scrollDirection: Axis.horizontal,
                    child: Row(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        FlashingFilterChip( // The "Hit" verb itself.
                          label: SizedBox(
                            width: _fixedChipWidth,
                            child: const Center(
                              child: Text('Hit', style: TextStyle(fontSize: 12), overflow: TextOverflow.ellipsis),
                            ),
                          ),
                          visualDensity: VisualDensity.compact,
                          padding: EdgeInsets.zero,
                          labelPadding: const EdgeInsets.symmetric(horizontal: 6), // Consistent padding
                          materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                          selected: _showHitTypes, // This controls its selected state
                          onSelected: (_showHomeFirst ? selectedPlayers.isNotEmpty : selectedOpponentPlayers.isNotEmpty)
                              ? (isSelected) {
                                  setState(() {
                                    if (isSelected) { // Chip is being selected
                                      _selectedVerb = 'hit';
                                      _selectedRbiInning = null;
                                      _customInningText = null;
                                      _showExtraInnings = false;
                                      _showHitTypes = true; // Show hit options
                                      // Reset fielding options
                                      _showFieldingOptions = false;
                                      _selectedFieldingAction = null;
                                      _showDivingCatch = false;
                                      _isDivingCatch = false;
                                    } else { // Chip is being deselected
                                      _selectedVerb = null;
                                      _showHitTypes = false; // Hide hit options
                                      _selectedHitType = null;
                                      _selectedHomeRunType = null;
                                      _rbiCount = null;
                                      _selectedRbiInning = null;
                                      _isBatterRunning = null;
                                    }
                                    _updateCaption();
                                  });
                                } : null,
                        ),
                        // This block handles the sequential selection for a "hit"
                        if (_showHitTypes) ...[ // This block now follows the hit chip
                          const SizedBox(width: 2),
                          // STEP 1: Show hit type choices OR the selected chip
                          if (_selectedHitType == null) ...[
                            _buildArrow(),
                            const SizedBox(width: 2),
                            Row(
                              children: ['single', 'double', 'triple', 'home run'].map((label) {
                                return Padding(
                                  padding: const EdgeInsets.only(right: 2.0),
                                  child: FlashingFilterChip(
                                    key: _hitChipKeys[label],
                                    label: SizedBox(
                                      width: _selectedHitType == label ? 94.0 : _fixedChipWidth,
                                      child: Center(
                                        child: Text(label, style: const TextStyle(fontSize: 12), overflow: TextOverflow.ellipsis),
                                      ),
                                    ),
                                    showCheckmark: true,
                                    visualDensity: VisualDensity.compact,
                                    padding: EdgeInsets.zero,
                                    labelPadding: const EdgeInsets.symmetric(horizontal: 8),
                                    materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                                    selected: _selectedHitType == label,
                                    onSelected: (_showHomeFirst ? selectedPlayers.isNotEmpty : selectedOpponentPlayers.isNotEmpty)
                                        ? (isSelected) {
                                            setState(() {
                                              // Save previous selections for old hit type
                                              if (_selectedHitType != null) {
                                                _rbiCountByHit[_selectedHitType!] = _rbiCount;
                                                _homeRunTypeByHit[_selectedHitType!] = _selectedHomeRunType;
                                                _inningByHit[_selectedHitType!] = _selectedRbiInning;
                                                _batterRunningByHit[_selectedHitType!] = _isBatterRunning;
                                              }
                                              // Switch to new hit type
                                              _selectedHitType = label;
                                              // Restore any saved selections for the new type
                                              _rbiCount = _rbiCountByHit[label];
                                              _selectedHomeRunType = _homeRunTypeByHit[label];
                                              _selectedRbiInning = _inningByHit[label];
                                              _isBatterRunning = _batterRunningByHit[label];
                                              _updateCaption();
                                            });
                                            WidgetsBinding.instance.addPostFrameCallback((_) {
                                              final rowContext = _hitRowKey.currentContext;
                                              final chipContext = _hitChipKeys[label]?.currentContext;
                                              if (rowContext == null || chipContext == null) return;
                                              final rowRender = rowContext.findRenderObject();
                                              final chipRender = chipContext.findRenderObject();
                                              if (rowRender is! RenderBox || chipRender is! RenderBox) return;
                                              final rowPos = rowRender.localToGlobal(Offset.zero);
                                              final chipPos = chipRender.localToGlobal(Offset.zero);
                                              setState(() {
                                                _batterIndent = chipPos.dx - rowPos.dx;
                                              });
                                            });
                                          }
                                        : null,
                                  ),
                                );
                              }).toList(),
                            ),
                          ] else ...[
                            // Show the selected hit type as an ActionChip (tappable to reset)
                            _buildArrow(),
                            const SizedBox(width: 2),
                            ActionChip(
                              key: _hitChipKeys[_selectedHitType!],
                              label: SizedBox(
                                width: _fixedChipWidth,
                                child: Center(
                                  child: Text(_selectedHitType!, style: const TextStyle(fontSize: 12), overflow: TextOverflow.ellipsis),
                                ),
                              ),
                              onPressed: () {
                                setState(() {
                                  _selectedHitType = null;
                                  _updateCaption();
                                });
                              },
                              visualDensity: VisualDensity.compact,
                              padding: const EdgeInsets.all(2),
                              materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                            ),

                            // STEP 2: Show next set of options based on hit type
                            if (_selectedHitType == 'home run') ...[
                              if (_selectedHomeRunType == null) ...[
                                const SizedBox(width: 2),
                              _buildArrow(),
                                const SizedBox(width: 2),
                                Row(
                                  children: ['solo', 'two-run', 'three-run', 'grand slam'].map((hrType) {
                                    return Padding(
                                      padding: const EdgeInsets.only(right: 2.0),
                                      child: FlashingFilterChip(
                                        label: Text(hrType == 'solo' ? 'Solo' : hrType == 'two-run' ? 'Two-run' : hrType == 'three-run' ? 'Three-run' : 'Grand Slam', style: const TextStyle(fontSize: 12)),
                                        visualDensity: VisualDensity.compact,
                                        padding: EdgeInsets.zero,
                                        labelPadding: const EdgeInsets.symmetric(horizontal: 8),
                                        materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                                        selected: false,
                                        onSelected: (isSelected) {
                                          setState(() {
                                            _homeRunTypeByHit[_selectedHitType!] = hrType;
                                            _selectedHomeRunType = hrType;
                                            _updateCaption();
                                          });
                                        },
                                      ),
                                    );
                                  }).toList(),
                                ),
                              ] else ...[
                                const SizedBox(width: 2),
                                _buildArrow(),
                                const SizedBox(width: 2),
                                Chip(
                                  label: Text(_selectedHomeRunType!, style: const TextStyle(fontSize: 12)),
                                  onDeleted: () {
                                    setState(() {
                                      _selectedHomeRunType = null;
                                      _selectedRbiInning = null;
                                      _customInningText = null;
                                      _updateCaption();
                                    });
                                  },
                                  visualDensity: VisualDensity.compact,
                                  padding: const EdgeInsets.all(2),
                                ),
                                _buildHitInningSelector(showWalkOffOption: true),
                              ],
                            ] else if (['single', 'double', 'triple'].contains(_selectedHitType)) ...[
                              if (_rbiCount == null) ...[
                                const SizedBox(width: 2),
                                _buildArrow(),
                                const SizedBox(width: 2),
                                Row(
                                  children: [0, 1, 2, 3].map((rbi) {
                                    return Padding(
                                      padding: const EdgeInsets.only(right: 2.0),
                                      child: FlashingFilterChip(
                                        label: Text(rbi == 0 ? 'No RBI' : '$rbi RBI', style: const TextStyle(fontSize: 11)),
                                        visualDensity: VisualDensity.compact,
                                        padding: EdgeInsets.zero,
                                        labelPadding: const EdgeInsets.symmetric(horizontal: 8),
                                        materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
                                        selected: false,
                                        onSelected: (isSelected) {
                                          setState(() {
                                            _rbiCountByHit[_selectedHitType!] = rbi;
                                            _rbiCount = rbi;
                                            _updateCaption();
                                          });
                                        },
                                      ),
                                    );
                                  }).toList(),
                                ),
                              ] else ...[
                                const SizedBox(width: 2),
                                _buildArrow(),
                                const SizedBox(width: 2),
                                Chip(
                                  label: Text(_rbiCount == 0 ? 'No RBI' : '$_rbiCount RBI', style: const TextStyle(fontSize: 11)),
                                  onDeleted: () {
                                    setState(() {
                                      _rbiCount = null;
                                      _selectedRbiInning = null;
                                      _customInningText = null;
                                      _updateCaption();
                                    });
                                  },
                                  visualDensity: VisualDensity.compact,
                                  padding: const EdgeInsets.all(2),
                                ),
                                _buildHitInningSelector(showWalkOffOption: true),
                              ],
                            ],
                          ],
                        ],
                      ],
                    ),
                  ),
                  // PATCH: Show "Optional" row above "Batter running" chip if hit type is selected
                  if (_selectedHitType != null)
                    Padding(
                      padding: EdgeInsets.only(left: _batterIndent),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          const Padding(
                            padding: EdgeInsets.only(top: 4.0),
                            child: Row(
                              mainAxisSize: MainAxisSize.min,
                              children: [
                                Text('↓', style: TextStyle(fontSize: 12)),
                                SizedBox(width: 4),
                                Text('Optional', style: TextStyle(fontSize: 12)),
                              ],
                            ),
                          ),
                          Padding(
                            padding: const EdgeInsets.only(top: 4.0),
                            child: FlashingFilterChip(
                              label: const SizedBox(
