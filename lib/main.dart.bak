  // Helper for fielding options
  Widget _buildFieldingOption(String actionKey, String label) {
    return Padding(
      padding: const EdgeInsets.only(top: 4.0),
      child: FlashingFilterChip(
        label: SizedBox(
          width: _fixedChipWidth,
          child: Center(
            child: Text(
              label,
              style: const TextStyle(fontSize: 12, fontWeight: FontWeight.normal),
              overflow: TextOverflow.ellipsis,
            ),
          ),
        ),
        selected: _selectedFieldingAction == actionKey,
        onSelected: (isSelected) {
          setState(() {
            if (isSelected) {
              _selectedFieldingAction = actionKey;
            } else {
              _selectedFieldingAction = null;
              _isDivingCatch = false; // Reset sub-option if parent is deselected
            }
            _updateCaption();
          });
        },
        visualDensity: VisualDensity.compact,
        padding: EdgeInsets.zero,
        labelPadding: const EdgeInsets.symmetric(horizontal: 8),
        materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
      ),
    );
  }

  Widget _buildDivingCatchOption() {
    return FlashingFilterChip(
      label: const Text('Diving catch', style: TextStyle(fontSize: 12, fontWeight: FontWeight.normal)),
      selected: _isDivingCatch == true,
      onSelected: (isSelected) {
        setState(() {
          _isDivingCatch = isSelected;
          _updateCaption();
        });
      },
      visualDensity: VisualDensity.compact,
      padding: EdgeInsets.zero,
      labelPadding: const EdgeInsets.symmetric(horizontal: 8),
      materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
    );
  }

  // Helper for 'Diving' option on 'Fields a ground ball'
  Widget _buildDivingForGroundBallOption() {
    return FlashingFilterChip(
      label: const Text('Diving', style: TextStyle(fontSize: 12, fontWeight: FontWeight.normal)),
      selected: _isDivingForGroundBall == true,
      onSelected: (isSelected) {
        setState(() {
          _isDivingForGroundBall = isSelected;
          _updateCaption();
        });
      },
      visualDensity: VisualDensity.compact,
      padding: EdgeInsets.zero,
      labelPadding: const EdgeInsets.symmetric(horizontal: 8),
      materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,
    );
  }

final List<String> soloVerbs = const [
    'hit',
    'swings',
    'At Bat',
    'pitches',
    'Fielding',
    'Portrait',
  ];
  Map<String, List<String>> get verbCategories => {
    'Actions': soloVerbs,
  };

  // ── Info section ─────────────────────────────
  DateTime selectedDate = DateTime.now();
  final photographerController = TextEditingController(text: 'Mark Blinch');
  final stadiumController    = TextEditingController(text: 'Rogers Centre');
  final cityController       = TextEditingController(text: 'Toronto');
  final provinceController   = TextEditingController(text: 'Ontario');
  String? selectedHomeTeam   = 'Toronto Blue Jays';
  String? selectedAwayTeam   = 'Chicago White Sox';

  // ── Image & IPTC ────────────────────────────
  List<String> imagePaths = [];
  int currentIndex = 0;

  // ── Code‐replacement data ───────────────────
  final Map<String, Replacement> codeReplacements = {};
  bool isHome = true; // This state variable might need to be managed more actively depending on UI flow
  Set<String> selectedPlayers = {}; // For home players or the primary player in solo actions
  Set<String> selectedOpponentPlayers = {}; // For opponent players in competition verbs
  String? _selectedVerb;
  String? selectedInning;
  bool _showDivingCatch = false;
  bool _showFieldingOptions = false;
  String? _selectedFieldingAction;
  bool _isDivingForGroundBall = false; // Added: State for 'Diving' on ground ball
  bool _isDivingCatch = false;
  List<String> celebrateWith = [];
  
  // Portrait options
  final GlobalKey _looksOnKey = GlobalKey();

  // Player search for inline player selection UI (not directly used in current fixed UI)
  String playerSearch = '';

  // ── Caption field ───────────────────────────
  final captionController = TextEditingController();

  @override
  void initState() {
    super.initState();
    // Initialize verb replacements
    final verbMap = {
      'at bat':   'takes an at bat in his batting stance against the',
      'swings':   'swings against the',
      'single':   'hits a single against the',
      'double':   'hits a double against the',
      'triple':   'hits a triple against the',
      'home run': 'hits a home run against the',
      'celebrates with': 'celebrates with',
      'pitches': 'delivers a pitch against the',
      'celebrates home run with': 'celebrates home run with',
      'makes a catch': 'makes a catch against the',
      'celebrates scoring with': 'celebrates scoring with', 
      'At Bat': 'takes an at bat in his batting stance against the', // New entry for the UI button text
      'celebrates defeating': 'celebrates defeating the',
      // Ensure all soloVerbs and competitionVerbs have entries in codeReplacements if they are to be used like this
      // For instance, 'turns a double play over' isn't in verbMap, so its 'full' form would be itself unless added.
    };
    verbMap.forEach((k, v) {
      codeReplacements[k] = Replacement(v, v, '');
    });
    // Ensure all solo verbs map to a full phrase including "against the"
    for (String verb in soloVerbs) {
      if (!codeReplacements.containsKey(verb)) {
        codeReplacements[verb] = Replacement(
          '$verb against the',
          verb,
          '',
        );
      }
    }
  }

  @override
  void dispose() {
    photographerController.dispose();
    stadiumController.dispose();
    cityController.dispose();
    provinceController.dispose();
    captionController.dispose();
    super.dispose();
  }

  Future<void> pickFolder() async {
    final dirPath = await FilePicker.platform.getDirectoryPath();
    if (dirPath == null) return;
    final files = Directory(dirPath)
        .listSync()
        .whereType<File>()
        .where((f) {
          final ext = p.extension(f.path).toLowerCase();
          return ['.jpg', '.jpeg', '.png', '.tif', '.tiff']
              .contains(ext);
        })
        .map((f) => f.path)
        .toList();
    if (files.isNotEmpty) {
      setState(() {
        imagePaths = files;
        currentIndex = 0;
      });
      await _loadMetadata();
    }
  }

  Future<void> pickCodeFile() async {
    final result = await FilePicker.platform.pickFiles();
    if (result?.files.single.path == null) return;
    final path = result!.files.single.path!;
    final lines = await File(path).readAsLines();
    for (var line in lines) {
      if (line.trim().isEmpty) continue;
      final parts = line.split('\t');
      if (parts.length >= 2) {
        final code  = parts[0];
        final full  = parts[1];
        final short = parts.length > 2 ? parts[2] : full;
        final first = parts.length > 3 ? parts[3] : '';
        codeReplacements[code] = Replacement(full, short, first);
      }
    }
    setState(() {
      selectedPlayers.clear();
      selectedOpponentPlayers.clear(); // Clear opponent players too
      _selectedVerb    = null;
      selectedInning   = null;
      celebrateWith.clear();
    });
    _updateCaption();
  }

  Future<void> _loadMetadata() async {
    // Check if imagePaths is not empty before trying to access currentIndex
    if (imagePaths.isEmpty) return;

    final proc = await Process.run('exiftool', ['-j', imagePaths[currentIndex]]);
    if (proc.exitCode == 0) {
      final List data = jsonDecode(proc.stdout as String);
      // load IPTC here if you like...
      // Consider updating UI based on loaded metadata if applicable
    }
  }

  Future<void> nextImage() async {
    if (currentIndex < imagePaths.length - 1) {
      setState(() => currentIndex++);
      await _loadMetadata();
      _updateCaption(); // Update caption for new image
    }
  }

  Future<void> previousImage() async {
    if (currentIndex > 0) {
      setState(() => currentIndex--);
      await _loadMetadata();
      _updateCaption(); // Update caption for new image
    }
  }

  void _pickDate() async {
    final d = await showDatePicker(
      context: context,
      initialDate: selectedDate,
      firstDate: DateTime(2000),
      lastDate: DateTime(2100),
    );
    if (d != null) {
      setState(() => selectedDate = d);
      _updateCaption();
    }
  }

  Future<void> _showCelebrateDialog() async {
    // Determine which roster to show based on `isHome` for the "celebrator"
    final roster = (isHome
        ? codeReplacements.keys.where((k) => k.startsWith('h'))
        : codeReplacements.keys.where((k) => k.startsWith('v')))
        .toList()
      ..sort();

    Set<String> temp = celebrateWith.toSet();
    String search = '';

    await showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      builder: (BuildContext ctx) {
        return StatefulBuilder(
          builder: (BuildContext innerCtx, StateSetter setSheetState) {
            final filtered = roster.where((code) {
              final replacement = codeReplacements[code];
              if (replacement == null) return false;
              final player = replacement.short.toLowerCase();
              return player.contains(search.toLowerCase());
            }).toList();

            return Padding(
              padding: EdgeInsets.only(
                bottom: MediaQuery.of(ctx).viewInsets.bottom,
                top: 12, left: 16, right: 16),
              child: SizedBox(
                height: MediaQuery.of(ctx).size.height * 0.6,
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  children: [
                    SizedBox(
                      width: 180,
                      child: TextField(
                        decoration: const InputDecoration(
                          labelText: 'Search teammates',
                          prefixIcon: Icon(Icons.search),
                          isDense: true,
                          contentPadding: EdgeInsets.symmetric(vertical: 4, horizontal: 8),
                        ),
                        style: const TextStyle(fontSize: 12),
                        onChanged: (value) => setSheetState(() => search = value),
                      ),
                    ),
                    const SizedBox(height: 8),
                    Expanded(
                      child: ListView(
                        shrinkWrap: true,
                        children: filtered.map((code) {
                          final replacement = codeReplacements[code] ?? Replacement('', '', '');
                          return CheckboxListTile(
                            value: temp.contains(code),
                            title: Text(replacement.short),
                            onChanged: (checked) {
                              setSheetState(() {
                                if (checked == true) {
                                  temp.add(code);
                                } else {
                                  temp.remove(code);
                                }
                              });
                            },
                          );
                        }).toList(),
                      ),
                    ),
                    Row(
                      mainAxisAlignment: MainAxisAlignment.spaceBetween,
                      children: [
                        TextButton(onPressed: () => setSheetState(() => temp.clear()), child: const Text('Clear')),
                        TextButton(onPressed: () => Navigator.of(ctx).pop(), child: const Text('Cancel')),
                        TextButton(
                          onPressed: () {
                            celebrateWith = temp.toList();
                            _updateCaption();
                            Navigator.of(ctx).pop();
                          },
                          child: const Text('Done'),
                        ),
                      ],
                    )
                  ],
                ),
              ),
            );
          }
        );
      }
    );
  }

  String _combinePlayersWithSingleTeam(List<String> codes) {
    if (codes.isEmpty) return '';
    final shorts = codes.map((c) => (codeReplacements[c] ?? Replacement('', '', '')).short).toList();
    // Determine the team from the first player's code to infer if it's home or away
    final isHomeTeamPlayer = codes.first.startsWith('h');
    final prefixTeam = isHomeTeamPlayer ? selectedHomeTeam! : selectedAwayTeam!;

    if (shorts.length == 1) {
      return '${shorts.first} of the $prefixTeam';
    }

    final last = shorts.removeLast();
    return '${shorts.join(', ')} and $last of the $prefixTeam';
  }

  // Helper for competition verbs: combine home and opponent players - this is for specific phrasing
  String _combineCompetitionPlayers(List<String> homeCodes, List<String> oppCodes) {
    final homeShorts = homeCodes.map((c) => (codeReplacements[c] ?? Replacement('', '', '')).short).toList();
    final oppShorts = oppCodes.map((c) => (codeReplacements[c] ?? Replacement('', '', '')).short).toList();
    String teamA = selectedHomeTeam!; // Assuming homeCodes are always home team
    String teamB = selectedAwayTeam!; // Assuming oppCodes are always away team

    String homeStr = '';
    String oppStr = '';

    if (homeShorts.isNotEmpty) {
      if (homeShorts.length == 1) {
        homeStr = '${homeShorts.first} of the $teamA';
      } else {
        final last = homeShorts.removeLast();
        homeStr = '${homeShorts.join(', ')} and $last of the $teamA';
      }
    }
    if (oppShorts.isNotEmpty) {
      if (oppShorts.length == 1) {
        oppStr = '${oppShorts.first} of the $teamB';
      } else {
        final last = oppShorts.removeLast();
        oppStr = '${oppShorts.join(', ')} and $last of the $teamB';
      }
    }
    if (homeStr.isNotEmpty && oppStr.isNotEmpty) {
      return '$homeStr over $oppStr'; // This format seems specific to a "vs" type caption
    } else if (homeStr.isNotEmpty) {
      return homeStr;
    } else if (oppStr.isNotEmpty) {
      return oppStr;
    }
    return '';
  }

  // New helper function for hit verb's inning selection
  Widget _buildHitInningSelector({bool showWalkOffOption = false}) {
    return Row(
      crossAxisAlignment: CrossAxisAlignment.start, // Align children to the top
      mainAxisSize: MainAxisSize.min,
      children: [
        const SizedBox(width: 2),
        _buildArrow(),
        const SizedBox(width: 2),
        buildInlineInningSelector(
          showWalkOffOption: showWalkOffOption,
          selectedInning: _selectedRbiInning,
          showExtraInnings: _showExtraInnings,
          onInningSelected: (val) {
            setState(() {
              if (val == null) { // Clear selection
                _selectedRbiInning = null;
                _customInningText = null;
                _showExtraInnings = false;
              } else if (val == -1) { // Custom inning
                _customInningText = ''; // Signal custom input is pending
                _selectedRbiInning = null;
                _showExtraInnings = false;
              } else { // Numeric inning
                _selectedRbiInning = val;
                _customInningText = null;
                _showExtraInnings = false;
              }
              // Save inning per hit type
              if (_selectedHitType != null) {
                _inningByHit[_selectedHitType!] = _selectedRbiInning;
              }
              _updateCaption();
            });
          },
          onExtraToggle: () => setState(() => _showExtraInnings = true),
          allowCustom: true,
          onBack: () => setState(() => _showExtraInnings = false),
          currentCustomInningText: _customInningText,
        ),
        // Custom inning TextField, shown only when _customInningText is empty string
        if (_customInningText != null && _customInningText!.isEmpty)
          SizedBox(
            width: 70,
            child: TextField(
              autofocus: true,
              decoration: const InputDecoration(
                hintText: 'Inning',
                isDense: true,
                contentPadding: EdgeInsets.symmetric(vertical: 2.0, horizontal: 4.0),
              ),
              style: const TextStyle(fontSize: 11, fontWeight: FontWeight.bold),
              onChanged: (val) {
                setState(() {
                  _customInningText = val;
                  _updateCaption();
                });
              },
            ),
          ),
      ],
    );
  }

  // --- REVISED _updateCaption METHOD ---
  void _updateCaption() {
    final city = cityController.text;
    final prov = provinceController.text;
    final monLC = _month(selectedDate.month);
    final day = selectedDate.day;
    final year = selectedDate.year;

    String mainCaptionPart = '';
    if (_selectedHitType != null) {
      final activePlayers = _showHomeFirst ? selectedPlayers : selectedOpponentPlayers;
      final opponentTeamName = _showHomeFirst ? selectedAwayTeam! : selectedHomeTeam!;

      if (activePlayers.isEmpty) return; // Should not happen if UI is correct
      final playersString = _combinePlayersWithSingleTeam(activePlayers.toList());

      // 1. Determine the detailed hit phrase.
      String hitPhrase = '';

      if (_selectedHitType == 'home run') {
          String? hrType = _selectedHomeRunType;
          if (hrType == null) {
              switch (_rbiCount) {
                  case 0: hrType = 'solo'; break;
                  case 1: hrType = 'two-run'; break;
                  case 2: hrType = 'three-run'; break;
                  case 3: hrType = 'grand slam'; break;
              }
          }
          switch (hrType) {
              case 'solo': hitPhrase = 'solo home run'; break;
              case 'two-run': hitPhrase = 'two-run home run'; break;
              case 'three-run': hitPhrase = 'three-run home run'; break;
              case 'grand slam': 
                  // Special phrasing for walk-off grand slam
                  hitPhrase = (_walkOff == true) ? 'grand slam' : 'grand slam home run'; 
                  break;
              default: hitPhrase = 'home run';
          }
      } else { // single, double, triple
          if (_walkOff == true) {
              // Use "two-run double" style phrasing for walk-offs
              String rbiPart = '';
              if (_rbiCount != null && _rbiCount! > 0) {
                  if (_rbiCount == 1) {
                      rbiPart = 'RBI';
                  } else {
                      final rbiWords = {2: 'two', 3: 'three'};
                      rbiPart = rbiWords.containsKey(_rbiCount)
                          ? '${rbiWords[_rbiCount]}-run'
                          : '$_rbiCount-run';
                  }
              }
              hitPhrase = '$rbiPart $_selectedHitType'.trim();
          } else {
              // Use "two RBI double" style phrasing for standard hits
              if (_rbiCount == null || _rbiCount == 0) {
                  hitPhrase = _selectedHitType!;
              } else {
                  final rbiWords = ['one', 'two', 'three'];
                  final rbiString = _rbiCount == 1
                      ? 'RBI'
                      : _rbiCount! <= 3
                          ? '${rbiWords[_rbiCount! - 1]} RBI'
                          : '$_rbiCount RBI';
                  hitPhrase = '$rbiString $_selectedHitType';
              }
          }
      }

      // 2. Construct the sentence based on flags
      if (_walkOff == true && _isBatterRunning == true) {
          if (_selectedHitType == 'home run') {
              mainCaptionPart = "$playersString rounds the bases after hitting a walk-off $hitPhrase to defeat the $opponentTeamName";
          } else {
              mainCaptionPart = "$playersString runs after hitting a walk-off $hitPhrase to defeat the $opponentTeamName";
          }
      } else if (_walkOff == true) {
          mainCaptionPart = "$playersString hits a walk-off $hitPhrase to defeat the $opponentTeamName";
      } else if (_isBatterRunning == true) {
          if (_selectedHitType == 'home run') {
              mainCaptionPart = "$playersString rounds the bases after hitting a $hitPhrase against the $opponentTeamName";
          } else {
              mainCaptionPart = "$playersString runs after hitting a $hitPhrase against the $opponentTeamName";
          }
      } else {
          mainCaptionPart = "$playersString hits a $hitPhrase against the $opponentTeamName";
      }

      // 3. Add inning
      if (_customInningText != null && _customInningText!.isNotEmpty) {
        mainCaptionPart += ' in the ${_customInningText!} inning';
      } else if (_selectedRbiInning != null) {
        // Map 1–18 to written words
        const inningWords = [
          'first','second','third','fourth','fifth','sixth',
          'seventh','eighth','ninth','tenth','eleventh','twelfth',
          'thirteenth','fourteenth','fifteenth','sixteenth',
          'seventeenth','eighteenth'
        ];
        String word = (_selectedRbiInning! >= 1 && _selectedRbiInning! <= 18)
            ? inningWords[_selectedRbiInning! - 1]
            : '${_selectedRbiInning}th';
        mainCaptionPart += ' in the $word inning';
      }
    } else if (_selectedVerb == 'Fielding' && _selectedFieldingAction != null) {
      final activePlayers = _showHomeFirst ? selectedPlayers : selectedOpponentPlayers;
      final opponentTeamName = _showHomeFirst ? selectedAwayTeam! : selectedHomeTeam!;

      if (activePlayers.isEmpty) return; // Should not happen if UI is correct
      final playersString = _combinePlayersWithSingleTeam(activePlayers.toList());
      String actionPhrase = _selectedFieldingAction!;
      if (_selectedFieldingAction == 'makes a catch' && _isDivingCatch == true) {
        actionPhrase = 'makes a diving catch';
      } else if (_selectedFieldingAction == 'fields a ground ball' && _isDivingForGroundBall == true) {
        actionPhrase = 'dives for a ground ball';
      }
      mainCaptionPart = "$playersString $actionPhrase against the $opponentTeamName";
      // Add inning to Fielding caption
      if (_customInningText != null && _customInningText!.isNotEmpty) {
        mainCaptionPart += ' in the ${_customInningText!} inning';
      } else if (_selectedRbiInning != null) {
        const inningWords = [
          'first','second','third','fourth','fifth','sixth',
          'seventh','eighth','ninth','tenth','eleventh','twelfth',
          'thirteenth','fourteenth','fifteenth','sixteenth',
          'seventeenth','eighteenth'
        ];
        final idx = _selectedRbiInning! - 1;
        final word = (idx >= 0 && idx < inningWords.length)
            ? inningWords[idx]
            : '${_selectedRbiInning}th';
        mainCaptionPart += ' in the $word inning';
      }
    } else if (_selectedVerb == 'Portrait') {
      final activePlayers = _showHomeFirst ? selectedPlayers : selectedOpponentPlayers;
      final opponentTeamName = _showHomeFirst ? selectedAwayTeam! : selectedHomeTeam!;

      if (activePlayers.isEmpty) return; // Should not happen if UI is correct
      final playersString = _combinePlayersWithSingleTeam(activePlayers.toList());
      
      if (_isLooksOn) {
        mainCaptionPart = "$playersString of the $opponentTeamName looks on";
      } else {
        mainCaptionPart = "$playersString of the $opponentTeamName";
      }
      
      // Add inning if picked
      if (_customInningText != null && _customInningText!.isNotEmpty) {
        mainCaptionPart += ' in the ${_customInningText!} inning';
      } else if (_selectedRbiInning != null) {
        const inningWords = [
          'first','second','third','fourth','fifth','sixth',
          'seventh','eighth','ninth','tenth','eleventh','twelfth',
          'thirteenth','fourteenth','fifteenth','sixteenth',
          'seventeenth','eighteenth'
        ];
        final idx = _selectedRbiInning! - 1;
        final word = (idx >= 0 && idx < inningWords.length)
            ? inningWords[idx]
            : '${_selectedRbiInning}th';
        mainCaptionPart += ' in the $word inning';
      }
    } else if (_selectedVerb != null) {
      final activePlayers = _showHomeFirst ? selectedPlayers : selectedOpponentPlayers;
      final opponentTeamName = _showHomeFirst ? selectedAwayTeam! : selectedHomeTeam!;
      final opponentPlayers = _showHomeFirst ? selectedOpponentPlayers : selectedPlayers;
      final verbReplacement = codeReplacements[_selectedVerb!];

      if (verbReplacement == null) return; // Should not happen

      // Since all remaining verbs are solo actions, the logic is simplified.
      if (activePlayers.isNotEmpty) {
        final playersString = _combinePlayersWithSingleTeam(activePlayers.toList());
        mainCaptionPart = "$playersString ${verbReplacement.full} $opponentTeamName";
      }

      // Add inning if picked
      if (mainCaptionPart.isNotEmpty && (_customInningText != null || _selectedRbiInning != null)) {
        if (_customInningText != null && _customInningText!.isNotEmpty) {
          mainCaptionPart += ' in the ${_customInningText!} inning';
        } else if (_selectedRbiInning != null) {
          const inningWords = [
            'first','second','third','fourth','fifth','sixth',
            'seventh','eighth','ninth','tenth','eleventh','twelfth',
            'thirteenth','fourteenth','fifteenth','sixteenth',
            'seventeenth','eighteenth'
          ];
          final idx = _selectedRbiInning! - 1;
          final word = (idx >= 0 && idx < inningWords.length)
              ? inningWords[idx]
              : '${_selectedRbiInning}th';
          mainCaptionPart += ' in the $word inning';
        }
      }
    } else if (selectedPlayers.isNotEmpty || selectedOpponentPlayers.isNotEmpty) {
      // This is the new logic: if players are selected but no verb/hit, create a basic caption.
      final activePlayers = _showHomeFirst ? selectedPlayers : selectedOpponentPlayers;
      final inactivePlayers = _showHomeFirst ? selectedOpponentPlayers : selectedPlayers;

      if (activePlayers.isNotEmpty) {
        mainCaptionPart = _combinePlayersWithSingleTeam(activePlayers.toList());
      } else if (inactivePlayers.isNotEmpty) {
        mainCaptionPart = _combinePlayersWithSingleTeam(inactivePlayers.toList());
      }
    }

    // Write final caption
    final formattedDate = '$monLC $day, $year';
    final caption =
        "TORONTO, ON - ${monLC.toUpperCase()} $day: $mainCaptionPart in their MLB game at ${stadiumController.text} on $formattedDate in ${_capitalize(city)}, ${_capitalize(prov)}, Canada. (Photo by ${photographerController.text}/Getty Images)";
    captionController.text = caption.trim();
  }

  // Helper to get player text with "of the [Team]" for a code
  String playerText(String code) {
    final data = codeReplacements[code];
    if (data == null) return code;
    final teamName = code.startsWith('h')
        ? selectedHomeTeam ?? ''
        : code.startsWith('v')
            ? selectedAwayTeam ?? ''
            : '';
    return "${data.full} of the $teamName";
  }

  String _abbr(String prov) {
    switch (prov.toLowerCase()) {
      case 'ontario':         return 'ON';
      case 'british columbia': return 'BC';
      default:                 return prov.substring(0,2).toUpperCase();
    }
  }

  String _capitalize(String s) {
    if (s.isEmpty) return s;
    return s[0].toUpperCase() + s.substring(1).toLowerCase();
  }

